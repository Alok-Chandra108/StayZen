<%- layout("/layouts/boilerplate") -%>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
/* Brutalist Overrides for Flatpickr */
.flatpickr-calendar {
  border: 3px solid #0A0A0A !important;
  border-radius: 0 !important;
  box-shadow: 6px 6px 0 #0A0A0A !important;
  font-family: 'Space Grotesk', sans-serif !important;
}
.flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange, .flatpickr-day.selected.inRange, .flatpickr-day.startRange.inRange, .flatpickr-day.endRange.inRange, .flatpickr-day.selected:focus, .flatpickr-day.startRange:focus, .flatpickr-day.endRange:focus, .flatpickr-day.selected:hover, .flatpickr-day.startRange:hover, .flatpickr-day.endRange:hover, .flatpickr-day.selected.prevMonthDay, .flatpickr-day.startRange.prevMonthDay, .flatpickr-day.endRange.prevMonthDay, .flatpickr-day.selected.nextMonthDay, .flatpickr-day.startRange.nextMonthDay, .flatpickr-day.endRange.nextMonthDay {
  background: #C8FF00 !important;
  border-color: #0A0A0A !important;
  color: #0A0A0A !important;
  font-weight: 900 !important;
}
.sz-date-input {
  width: 100%;
  padding: 10px;
  border: 3px solid #0A0A0A;
  background: #f5f0e8;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 800;
  cursor: pointer;
}
.sz-view-ticket__total {
  background: #FF4D2E;
  color: #fff;
  padding: 15px;
  border: 3px solid #0A0A0A;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 15px;
  font-weight: 900;
}
</style>
<%
  const amenityIcons = {
    "WiFi": "fa-wifi", "Parking": "fa-square-parking", "Pool": "fa-water-ladder",
    "Air Conditioning": "fa-snowflake", "Heating": "fa-fire", "Kitchen": "fa-kitchen-set",
    "Washer": "fa-soap", "Dryer": "fa-tshirt", "Books & Reading Material": "fa-book",
    "Gym": "fa-dumbbell", "TV": "fa-tv", "Balcony": "fa-building",
    "Elevator": "fa-elevator", "Hot Tub": "fa-hot-tub-person", "BBQ Grill": "fa-fire-burner",
    "Fireplace": "fa-fire-flame-curved", "Outdoor Seating": "fa-chair", "Sound System": "fa-volume-high",
    "Workspace": "fa-laptop", "Pet Friendly": "fa-dog", "Smoking Allowed": "fa-smoking",
    "Security Cameras": "fa-video", "Breakfast Included": "fa-mug-hot", "Private Entrance": "fa-door-closed",
    "Wheelchair Accessible": "fa-wheelchair", "First Aid Kit": "fa-kit-medical", "Game Console": "fa-gamepad"
  };

  const listingDataJson = JSON.stringify({
      coordinates: (listing.geometry && listing.geometry.coordinates) ? [listing.geometry.coordinates[1], listing.geometry.coordinates[0]] : [0,0],
      title: listing.title,
      location: listing.location,
      price: listing.price
  });
%>
<script id="listing-data" type="application/json"><%- listingDataJson %></script>
<script>const listingData = JSON.parse(document.getElementById('listing-data').textContent);</script>

<!-- ===================== NEW BRUTALIST SHOW LAYOUT ===================== -->
<div class="sz-view-wrapper">

  <!-- Top Marquee -->
  <div class="sz-view-marquee sz-view-marquee--top">
    <div class="sz-view-marquee-track">
      <span><%= listing.title.toUpperCase() %> ✦ <%= listing.location.toUpperCase() %> ✦ </span>
      <span><%= listing.title.toUpperCase() %> ✦ <%= listing.location.toUpperCase() %> ✦ </span>
      <span><%= listing.title.toUpperCase() %> ✦ <%= listing.location.toUpperCase() %> ✦ </span>
      <span><%= listing.title.toUpperCase() %> ✦ <%= listing.location.toUpperCase() %> ✦ </span>
    </div>
  </div>

  <!-- Hero Section -->
  <div class="sz-view-hero">
    <!-- Offset decorative blocks -->
    <div class="sz-view-hero__bg-block sz-view-hero__bg-block--1"></div>
    <div class="sz-view-hero__bg-block sz-view-hero__bg-block--2"></div>

    <div class="sz-view-hero__content">
      <div class="sz-view-hero__image-box">
        <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
        <!-- Floating Price Stamp -->
        <div class="sz-stamp">
          <div class="sz-stamp-val">₹<%= listing.price.toLocaleString("en-IN") %></div>
          <div class="sz-stamp-unit">/NIGHT</div>
        </div>
      </div>
      <div class="sz-view-hero__title-box">
        <h1 class="sz-view-hero__title"><%= listing.title %></h1>
        <div class="sz-view-hero__meta">
          <span class="sz-view-badge sz-view-badge--owner"><i class="fa-solid fa-user me-2"></i>HOST: <%= listing.owner.username %></span>
          <span class="sz-view-badge sz-view-badge--loc"><i class="fa-solid fa-location-dot me-2"></i><%= listing.location %>, <%= listing.country %></span>
        </div>
      </div>
    </div>
  </div>

  <div class="sz-view-grid">
    <!-- LEFT CONTENT AREA -->
    <div class="sz-view-main">
      
      <!-- Description Section -->
      <section class="sz-view-section sz-view-desc-box">
        <h2 class="sz-view-section-title"><i class="fa-solid fa-bolt"></i> THE RUNDOWN</h2>
        <div class="sz-view-desc-text"><%= listing.description %></div>
      </section>

      <!-- Amenities Section -->
      <% if (listing.amenities && listing.amenities.length > 0) { %>
      <section class="sz-view-section sz-view-amenities-box">
        <h2 class="sz-view-section-title"><i class="fa-solid fa-list-check"></i> AMENITIES</h2>
        <div class="sz-view-amenities">
           <% listing.amenities.forEach((amenity) => {
                const icon = amenityIcons[amenity] || "fa-check";
           %>
             <div class="sz-view-amenity">
               <i class="fa-solid <%= icon %>"></i>
               <span><%= amenity %></span>
             </div>
           <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Tags Section -->
      <% if (listing.tags && listing.tags.length > 0) { %>
      <section class="sz-view-section">
        <div class="sz-view-tags">
          <% listing.tags.forEach(tag => { %>
            <div class="sz-view-tag-chip"><i class="fa-solid fa-hashtag me-1"></i><%= tag %></div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Map Section -->
      <section class="sz-view-section sz-view-map-box mt-4">
        <h2 class="sz-view-section-title"><i class="fa-solid fa-compass"></i> TERRITORY</h2>
        <div class="sz-view-map-container mt-2">
          <div id="map" class="sz-view-map"></div>
        </div>
      </section>

      <!-- Reviews Section -->
      <section class="sz-view-section sz-view-reviews-box mb-5">
        <h2 class="sz-view-section-title"><i class="fa-solid fa-star"></i> INTEL / REVIEWS [<%= listing.reviews.length %>]</h2>
        
        <% if(currUser) { %>
          <div class="sz-view-review-form">
            <h3 class="sz-view-review-form__header">LEAVE YOUR MARK</h3>
            <div class="sz-view-review-form__body">
              <form action="/listings/<%= listing.id %>/reviews" method="post" novalidate class="needs-validation">
                  <div class="sz-view-review-rating">
                    <label class="d-block mb-2 font-weight-bold" style="font-weight: 900; letter-spacing: 1px;">RATING:</label>
                    <fieldset class="starability-slot sz-view-stars">
                      <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                      <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                      <label for="first-rate1" title="Terrible">1 star</label>
                      <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                      <label for="first-rate2" title="Not good">2 stars</label>
                      <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                      <label for="first-rate3" title="Average">3 stars</label>
                      <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                      <label for="first-rate4" title="Very good">4 stars</label>
                      <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                      <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                  </div>
                  
                  <textarea name="review[comment]" cols="30" rows="3" class="sz-view-textarea form-control" required placeholder="Type your unfiltered thoughts..."></textarea>
                  <div class="invalid-feedback">Intel required. Don't leave it blank.</div>

                  <button class="sz-btn sz-btn--action w-100 mt-3" type="submit"><i class="fa-solid fa-bullhorn me-2"></i>DROP REVIEW</button>
              </form>
            </div>
          </div>
        <% } else { %>
          <div class="sz-alert-box mb-4 p-3 border border-dark rounded-0 bg-warning" style="font-weight:800; border-width: 3px !important; box-shadow: 4px 4px 0 #000;">
            You must be logged in to leave a review. <a href="/login" style="color:var(--ink);">Log in here →</a>
          </div>
        <% } %>

        <% if (listing.reviews.length > 0) { %>
          <div class="sz-view-review-list">
            <% for (let review of listing.reviews) { %>
              <div class="sz-view-review-card">
                 <div class="sz-view-review-card__top">
                    <span class="sz-view-review-author"><i class="fa-solid fa-user-ninja me-2"></i><%= review.author.username %></span>
                    <span class="sz-view-review-rating">
                      <% for (let i = 1; i <= 5; i++) { %>
                        <% if (i <= review.rating) { %> ★ <% } else { %> ☆ <% } %>
                      <% } %>
                    </span>
                 </div>
                 <p class="sz-view-review-text"><%= review.comment %></p>
                 
                 <% if (currUser && currUser._id.toString() === review.author._id.toString()) { %>
                  <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                    <button class="sz-view-btn-delete" title="Purge Review"><i class="fa-solid fa-trash-can"></i></button>
                  </form>
                 <% } %>
              </div>
            <% } %>
          </div>
        <% } %>
      </section>

    </div><!-- /sz-view-main -->

    <!-- RIGHT FIXED ACTION SIDEBAR -->
    <div class="sz-view-sidebar">
      <div class="sz-view-ticket">
        <div class="sz-view-ticket__punch sz-view-ticket__punch--left"></div>
        <div class="sz-view-ticket__punch sz-view-ticket__punch--right"></div>
        
        <div class="sz-view-ticket__header">
          <div class="sz-view-ticket__eyebrow">CLEARANCE PASS</div>
          <div class="sz-view-ticket__price">₹<%= listing.price.toLocaleString("en-IN") %></div>
          <div class="sz-view-ticket__per">PER NIGHT</div>
        </div>
        
        <div class="sz-view-ticket__body">
          <div class="sz-view-ticket__row">
            <span>LOC.</span>
            <strong><%= listing.location %></strong>
          </div>
          <div class="sz-view-ticket__row">
            <span>HOST</span>
            <strong><%= listing.owner.username %></strong>
          </div>
          <div class="sz-view-ticket__row">
            <span>RATING</span>
            <strong><%= listing.reviews.length > 0 ? listing.reviews.length + ' LOGGED' : 'NO DATA' %></strong>
          </div>

          <% if (!currUser || !currUser._id.equals(listing.owner._id)) { %>
            <form action="/listings/<%= listing.id %>/bookings" method="POST" id="booking-form" class="mt-4">
              <label style="font-size: 0.8rem; font-weight: 800; display:block; margin-bottom: 5px;">SELECT DATES</label>
              <div style="display: flex; gap: 10px;">
                <input type="text" id="checkIn" name="checkIn" class="sz-date-input" placeholder="CHECK-IN" required readonly>
                <input type="text" id="checkOut" name="checkOut" class="sz-date-input" placeholder="CHECK-OUT" required readonly>
              </div>

              <div class="sz-view-ticket__total" style="display: none;" id="brutal-total-box">
                <span>TOTAL FOR <span id="brutal-nights">0</span> NIGHTS</span>
                <strong id="brutal-price">₹0</strong>
              </div>
            </form>
          <% } %>
        </div>
        
        <div class="sz-view-ticket__footer">
          <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
             <a href="/listings/<%= listing._id %>/edit" class="sz-btn sz-btn--warn w-100 mb-2"><i class="fa-solid fa-pen-ruler me-2"></i>REVISE</a>
             <form method="Post" action="/listings/<%= listing._id %>?_method=DELETE" class="w-100">
               <button class="sz-btn sz-btn--danger w-100"><i class="fa-solid fa-biohazard me-2"></i>OBLITERATE</button>
             </form>
          <% } else { %>
             <button type="submit" form="booking-form" class="sz-btn sz-btn--action w-100"><i class="fa-solid fa-bolt me-2"></i>SECURE PASS</button>
          <% } %>
        </div>
      </div>
    </div><!-- /sz-view-sidebar -->

  </div><!-- /sz-view-grid -->
</div><!-- /sz-view-wrapper -->

<script src="/js/map.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const checkInInput = document.getElementById('checkIn');
    const checkOutInput = document.getElementById('checkOut');
    const totalBox = document.getElementById('brutal-total-box');
    const nightsSpan = document.getElementById('brutal-nights');
    const priceSpan = document.getElementById('brutal-price');
    
    // Listing data from server variables
    const pricePerNight = <%= listing.price %>;
    
    if(!checkInInput) return; // Owner viewing

    let checkOutPicker;

    const checkInPicker = flatpickr(checkInInput, {
      minDate: "today",
      onChange: function(selectedDates, dateStr, instance) {
        checkOutPicker.set('minDate', dateStr);
        calculateTotal();
      }
    });

    checkOutPicker = flatpickr(checkOutInput, {
      minDate: "today",
      onChange: function(selectedDates, dateStr, instance) {
        calculateTotal();
      }
    });

    function calculateTotal() {
      if(checkInInput.value && checkOutInput.value) {
        const d1 = new Date(checkInInput.value);
        const d2 = new Date(checkOutInput.value);
        const diffTime = d2 - d1;
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); 
        
        if(diffDays > 0) {
           nightsSpan.textContent = diffDays;
           priceSpan.textContent = "₹" + (diffDays * pricePerNight).toLocaleString("en-IN");
           totalBox.style.display = "flex";
        } else {
           totalBox.style.display = "none";
        }
      }
    }
  });
</script>