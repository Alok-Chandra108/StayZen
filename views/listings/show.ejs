<%- layout("/layouts/boilerplate") -%>
<%
  const amenityIcons = {
    "WiFi": "fa-wifi", "Parking": "fa-square-parking", "Pool": "fa-water-ladder",
    "Air Conditioning": "fa-snowflake", "Heating": "fa-fire", "Kitchen": "fa-kitchen-set",
    "Washer": "fa-soap", "Dryer": "fa-tshirt", "Books & Reading Material": "fa-book",
    "Gym": "fa-dumbbell", "TV": "fa-tv", "Balcony": "fa-building",
    "Elevator": "fa-elevator", "Hot Tub": "fa-hot-tub-person", "BBQ Grill": "fa-fire-burner",
    "Fireplace": "fa-fire-flame-curved", "Outdoor Seating": "fa-chair", "Sound System": "fa-volume-high",
    "Workspace": "fa-laptop", "Pet Friendly": "fa-dog", "Smoking Allowed": "fa-smoking",
    "Security Cameras": "fa-video", "Breakfast Included": "fa-mug-hot", "Private Entrance": "fa-door-closed",
    "Wheelchair Accessible": "fa-wheelchair", "First Aid Kit": "fa-kit-medical", "Game Console": "fa-gamepad"
  };

  const listingDataJson = JSON.stringify({
      coordinates: (listing.geometry && listing.geometry.coordinates) ? [listing.geometry.coordinates[1], listing.geometry.coordinates[0]] : [0,0],
      title: listing.title,
      location: listing.location,
      price: listing.price,
      bookings: typeof bookings !== 'undefined' ? bookings : []
  });
%>
<script id="listing-data" type="application/json"><%- listingDataJson %></script>
<script>const listingData = JSON.parse(document.getElementById('listing-data').textContent);</script>

<!-- ===================== NEW BRUTALIST SHOW LAYOUT ===================== -->
<div class="sz-view-wrapper">

  <!-- Top Marquee -->
  <div class="sz-view-marquee sz-view-marquee--top">
    <div class="sz-view-marquee-track">
      <span><%= listing.title.toUpperCase() %> ✦ <%= listing.location.toUpperCase() %> ✦ </span>
      <span><%= listing.title.toUpperCase() %> ✦ <%= listing.location.toUpperCase() %> ✦ </span>
      <span><%= listing.title.toUpperCase() %> ✦ <%= listing.location.toUpperCase() %> ✦ </span>
      <span><%= listing.title.toUpperCase() %> ✦ <%= listing.location.toUpperCase() %> ✦ </span>
    </div>
  </div>

  <!-- Hero Section -->
  <div class="sz-view-hero">
    <!-- Offset decorative blocks -->
    <div class="sz-view-hero__bg-block sz-view-hero__bg-block--1"></div>
    <div class="sz-view-hero__bg-block sz-view-hero__bg-block--2"></div>

    <div class="sz-view-hero__content">
      <div class="sz-view-hero__image-box">
        <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
        <!-- Floating Price Stamp -->
        <div class="sz-stamp">
          <div class="sz-stamp-val">₹<%= listing.price.toLocaleString("en-IN") %></div>
          <div class="sz-stamp-unit">/NIGHT</div>
        </div>
      </div>
      <div class="sz-view-hero__title-box">
        <h1 class="sz-view-hero__title"><%= listing.title %></h1>
        <div class="sz-view-hero__meta">
          <span class="sz-view-badge sz-view-badge--owner"><i class="fa-solid fa-user me-2"></i>HOST: <%= listing.owner.username %></span>
          <span class="sz-view-badge sz-view-badge--loc"><i class="fa-solid fa-location-dot me-2"></i><%= listing.location %>, <%= listing.country %></span>
        </div>
      </div>
    </div>
  </div>

  <div class="sz-view-grid">
    <!-- LEFT CONTENT AREA -->
    <div class="sz-view-main">
      
      <!-- Description Section -->
      <section class="sz-view-section sz-view-desc-box">
        <h2 class="sz-view-section-title"><i class="fa-solid fa-bolt"></i> THE RUNDOWN</h2>
        <div class="sz-view-desc-text"><%= listing.description %></div>
      </section>

      <!-- Amenities Section -->
      <% if (listing.amenities && listing.amenities.length > 0) { %>
      <section class="sz-view-section sz-view-amenities-box">
        <h2 class="sz-view-section-title"><i class="fa-solid fa-list-check"></i> AMENITIES</h2>
        <div class="sz-view-amenities">
           <% listing.amenities.forEach((amenity) => {
                const icon = amenityIcons[amenity] || "fa-check";
           %>
             <div class="sz-view-amenity">
               <i class="fa-solid <%= icon %>"></i>
               <span><%= amenity %></span>
             </div>
           <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Tags Section -->
      <% if (listing.tags && listing.tags.length > 0) { %>
      <section class="sz-view-section">
        <div class="sz-view-tags">
          <% listing.tags.forEach(tag => { %>
            <div class="sz-view-tag-chip"><i class="fa-solid fa-hashtag me-1"></i><%= tag %></div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Map Section -->
      <section class="sz-view-section sz-view-map-box mt-4">
        <h2 class="sz-view-section-title"><i class="fa-solid fa-compass"></i> LOCATION</h2>

        <div class="sz-view-map-container mt-2">
          <div id="map" class="sz-view-map"></div>
        </div>
      </section>

      <!-- Reviews Section -->
      <section class="sz-view-section sz-view-reviews-box mb-5">
        <h2 class="sz-view-section-title"><i class="fa-solid fa-star"></i> REVIEWS [<%= listing.reviews.length %>]</h2>

        
        <% if(currUser) { %>
          <div class="sz-view-review-form">
            <h3 class="sz-view-review-form__header">LEAVE YOUR MARK</h3>
            <div class="sz-view-review-form__body">
              <form action="/listings/<%= listing.id %>/reviews" method="post" novalidate class="needs-validation">
                  <div class="sz-view-review-rating">
                    <label class="d-block mb-2 font-weight-bold" style="font-weight: 900; letter-spacing: 1px;">RATING:</label>
                    <fieldset class="starability-slot sz-view-stars">
                      <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                      <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                      <label for="first-rate1" title="Terrible">1 star</label>
                      <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                      <label for="first-rate2" title="Not good">2 stars</label>
                      <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                      <label for="first-rate3" title="Average">3 stars</label>
                      <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                      <label for="first-rate4" title="Very good">4 stars</label>
                      <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                      <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                  </div>
                  
                  <textarea name="review[comment]" cols="30" rows="3" class="sz-view-textarea form-control" required placeholder="Type your unfiltered thoughts..."></textarea>
                  <div class="invalid-feedback">Comment required. Don't leave it blank.</div>


                  <button class="sz-btn sz-btn--action w-100 mt-3" type="submit"><i class="fa-solid fa-bullhorn me-2"></i>DROP REVIEW</button>
              </form>
            </div>
          </div>
        <% } else { %>
          <div class="sz-alert-box mb-4 p-3 border border-dark rounded-0 bg-warning" style="font-weight:800; border-width: 3px !important; box-shadow: 4px 4px 0 #000;">
            You must be logged in to leave a review. <a href="/login" style="color:var(--ink);">Log in here →</a>
          </div>
        <% } %>

        <% if (listing.reviews.length > 0) { %>
          <div class="sz-view-review-list">
            <% for (let review of listing.reviews) { %>
              <div class="sz-view-review-card">
                 <div class="sz-view-review-card__top">
                    <span class="sz-view-review-author"><i class="fa-solid fa-user-ninja me-2"></i><%= review.author.username %></span>
                    <span class="sz-view-review-rating">
                      <% for (let i = 1; i <= 5; i++) { %>
                        <% if (i <= review.rating) { %> ★ <% } else { %> ☆ <% } %>
                      <% } %>
                    </span>
                 </div>
                 <p class="sz-view-review-text"><%= review.comment %></p>
                 
                 <% if (currUser && currUser._id.toString() === review.author._id.toString()) { %>
                  <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                    <button class="sz-view-btn-delete" title="Delete Review"><i class="fa-solid fa-trash-can"></i></button>
                  </form>

                 <% } %>
              </div>
            <% } %>
          </div>
        <% } %>
      </section>

    </div><!-- /sz-view-main -->

    <!-- RIGHT FIXED ACTION SIDEBAR -->
    <div class="sz-view-sidebar">
      <div class="sz-view-ticket">
        <div class="sz-view-ticket__punch sz-view-ticket__punch--left"></div>
        <div class="sz-view-ticket__punch sz-view-ticket__punch--right"></div>
        
        <div class="sz-view-ticket__header">
          <div class="sz-view-ticket__eyebrow">BOOKING PASS</div>
          <div class="sz-view-ticket__price">₹<%= listing.price.toLocaleString("en-IN") %></div>

          <div class="sz-view-ticket__per">PER NIGHT</div>
        </div>
        
        <div class="sz-view-ticket__body">
          <div class="sz-view-ticket__row">
            <span>LOC.</span>
            <strong><%= listing.location %></strong>
          </div>
          <div class="sz-view-ticket__row">
            <span>HOST</span>
            <strong><%= listing.owner.username %></strong>
          </div>
          <div class="sz-view-ticket__row">
            <span>STATUS</span>
            <strong><%= listing.reviews.length > 0 ? listing.reviews.length + ' REVIEWS' : 'NEW LISTING' %></strong>
          </div>


          <% if (!currUser || !currUser._id.equals(listing.owner._id)) { %>
            <form action="/listings/<%= listing.id %>/bookings" method="POST" id="booking-form" class="mt-4">
              <label style="font-size: 0.8rem; font-weight: 800; display:block; margin-bottom: 5px;">SELECT DATES</label>
              
              <input type="hidden" id="hiddenCheckIn" name="checkIn" required>
              <input type="hidden" id="hiddenCheckOut" name="checkOut" required>
              
              <div style="display: flex; gap: 10px;">
                <input type="text" id="checkIn" class="sz-date-input" placeholder="CHECK-IN" readonly>
                <input type="text" id="checkOut" class="sz-date-input" placeholder="CHECK-OUT" readonly>
              </div>

              <div id="lock-status-container" style="display: none; margin-top: 1rem;">
                <!-- Locked status will be injected here -->
              </div>

              <div id="brutal-total-box" style="display: none; flex-direction: column; gap: 4px; padding: 1rem; border-top: 3px dashed var(--ink); margin-top: 1rem;">
                <div style="display: flex; justify-content: space-between; font-size: 0.75rem; font-weight: 800;">
                  <span>PRICE FOR (<span id="brutal-nights">0</span> NIGHTS)</span>
                  <span id="brutal-subtotal">₹0</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-size: 0.75rem; font-weight: 800; color: var(--coral);">
                  <span>GOVERNMENT TAX (18%)</span>
                  <span id="brutal-tax">₹0</span>
                </div>

                <div style="display: flex; justify-content: space-between; margin-top: 8px; border-top: 2px solid var(--ink); padding-top: 8px;">
                  <span style="font-weight: 900; font-size: 0.85rem;">GRAND TOTAL</span>
                  <strong id="brutal-grand-total" style="font-size: 1.2rem; font-weight: 900;">₹0</strong>
                </div>
              </div>
            </form>
          <% } %>
        </div>
        
        <div class="sz-view-ticket__footer">
          <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
             <a href="/listings/<%= listing._id %>/edit" class="sz-btn sz-btn--warn w-100 mb-2"><i class="fa-solid fa-pen-ruler me-2"></i>EDIT LISTING</a>
             <form method="Post" action="/listings/<%= listing._id %>?_method=DELETE" class="w-100">
                <button class="sz-btn sz-btn--danger w-100"><i class="fa-solid fa-trash-can me-2"></i>DELETE LISTING</button>
             </form>
          <% } else { %>
             <button type="submit" form="booking-form" class="sz-btn sz-btn--action w-100"><i class="fa-solid fa-bolt me-2"></i>BOOK NOW</button>
          <% } %>
        </div>

      </div>
    </div><!-- /sz-view-sidebar -->

  </div><!-- /sz-view-grid -->
</div><!-- /sz-view-wrapper -->

<script src="/js/map.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const checkInInput = document.getElementById('checkIn');
    const checkOutInput = document.getElementById('checkOut');
    const totalBox = document.getElementById('brutal-total-box');
    const nightsSpan = document.getElementById('brutal-nights');
    const priceSpan = document.getElementById('brutal-price');
    const hiddenCheckIn = document.getElementById('hiddenCheckIn');
    const hiddenCheckOut = document.getElementById('hiddenCheckOut');
    const lockContainer = document.getElementById('lock-status-container');
    
    // Listing data from the JSON script tag
    const pricePerNight = listingData.price;
    const rawBookings = listingData.bookings;
    const listingId = listingData.id || '<%= listing._id %>';
    
    // Format disabled ranges
    const disabledRanges = rawBookings.map(b => ({
       from: b.checkIn,
       to: b.checkOut
    }));
    
    if(!checkInInput) return; // Owner view

    // Initialize Flatpickr
    const fp = flatpickr(checkInInput, {
      mode: "range",
      minDate: "today",
      disable: disabledRanges,
      showMonths: window.innerWidth > 992 ? 2 : 1,
      altInput: true,
      altFormat: "M j, Y",
      dateFormat: "Y-m-d",
      onValueUpdate: function(selectedDates, dateStr, instance) {
        if (selectedDates.length >= 1) {
          setTimeout(() => {
            if (instance.altInput) {
              instance.altInput.value = instance.formatDate(selectedDates[0], "M j, Y");
            }
          }, 0);
          hiddenCheckIn.value = instance.formatDate(selectedDates[0], "Y-m-d");
        }
        
        if (selectedDates.length === 2) {
          checkOutInput.value = instance.formatDate(selectedDates[1], "M j, Y");
          hiddenCheckOut.value = instance.formatDate(selectedDates[1], "Y-m-d");
          calculateTotal(selectedDates[0], selectedDates[1]);
          checkLockStatus(hiddenCheckIn.value, hiddenCheckOut.value);
        } else {
          checkOutInput.value = "";
          hiddenCheckOut.value = "";
          totalBox.style.display = "none";
          if(lockContainer) lockContainer.style.display = 'none';
        }
      },
      onClose: function(selectedDates, dateStr, instance) {
        if (selectedDates.length === 1 && instance.altInput) {
          instance.altInput.value = instance.formatDate(selectedDates[0], "M j, Y");
        }
      },
      onDayCreate: function(dObj, dStr, fp, dayElem) {
        const date = dayElem.dateObj;
        date.setHours(0,0,0,0);
        const isBooked = rawBookings.some(b => {
            const start = new Date(b.checkIn);
            const end = new Date(b.checkOut);
            start.setHours(0,0,0,0);
            end.setHours(0,0,0,0);
            return date >= start && date <= end;
        });
        if (isBooked) {
          dayElem.classList.add("sz-booked-cell");
          dayElem.title = "This date is already reserved";
        }
      }
    });

    document.getElementById('booking-form').addEventListener('submit', function(e) {
        if(!hiddenCheckIn.value || !hiddenCheckOut.value) {
            e.preventDefault();
            alert("Please select a complete Check-In and Check-Out date range.");
        }
    });

    checkOutInput.addEventListener('click', () => fp.open());
    checkOutInput.readOnly = true;

    function calculateTotal(d1, d2) {
        const diffDays = Math.ceil(Math.abs(d2 - d1) / (1000 * 60 * 60 * 24)); 
        const subtotalSpan = document.getElementById('brutal-subtotal');
        const taxSpan = document.getElementById('brutal-tax');
        const grandTotalSpan = document.getElementById('brutal-grand-total');

        if(diffDays > 0) {
           const subtotal = diffDays * pricePerNight;
           const tax = subtotal * 0.18;
           const grandTotal = subtotal + tax;

           nightsSpan.textContent = diffDays;
           subtotalSpan.textContent = "₹" + subtotal.toLocaleString("en-IN");
           taxSpan.textContent = "₹" + tax.toLocaleString("en-IN");
           grandTotalSpan.textContent = "₹" + grandTotal.toLocaleString("en-IN");
           
           totalBox.style.display = "flex";
        } else {
           totalBox.style.display = "none";
        }
    }

    async function checkLockStatus(checkIn, checkOut) {
        if(!lockContainer) return;
        try {
            const response = await fetch(`/api/listings/${listingId}/check-lock?checkIn=${checkIn}&checkOut=${checkOut}`);
            const data = await response.json();
            if (data.locked) {
                lockContainer.innerHTML = `
                    <div style="background: var(--yellow); border: 3px solid var(--ink); padding: 1rem; box-shadow: 4px 4px 0 var(--ink); display: flex; align-items: center; gap: 10px;">
                        <i class="fa-solid fa-triangle-exclamation" style="font-size: 1.5rem;"></i>
                        <div style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">
                            WARNING: Dates currently being selected by another user.
                        </div>
                    </div>

                `;
                lockContainer.style.display = 'block';
            } else {
                lockContainer.style.display = 'none';
            }
        } catch (err) {
            console.error("Lock check failed:", err);
        }
    }
  });
</script>