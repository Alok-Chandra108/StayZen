<% layout("/layouts/boilerplate") %>

<body>
    <div class="row justify-content-center bg-brutal-stripes py-5">
        <div class="col-10 col-md-8">
            <div class="brutal-form-container">
                <h3 class="mb-4" style="font-weight: 900; font-size: 2.5rem; text-transform: uppercase;">Create a new listing</h3>
                <form method="POST" action="/listings" class="needs-validation" enctype="multipart/form-data" novalidate>
                    <div class="mb-4 mt-2">
                        <label for="title" class="form-label">Title</label>
                        <input name="listing[title]" placeholder="Enter title" type="text" class="form-control border border-3 border-dark" style="box-shadow: inset 4px 4px 0px rgba(0,0,0,0.05);" required>
                        <div class="valid-feedback">Looks Good</div>
                    </div>

        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" placeholder="Enter description" class="form-control" required></textarea>
            <div class="invalid-feedback">A short description please</div>

        </div>

        <div class="mb-3">
            <label for="image" class="form-label">Upload Image</label>
            <input name="listing[image]" type="file" class="form-control" required>
        </div>
        
        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price</label>
            <input name="listing[price]" placeholder="Enter price" class="form-control" required>
            <div class="invalid-feedback">Enter the valid Price</div>

            </div>
    
            <div class="mb-3 col-md-8">
                <label for="Country" class="form-label">Country</label>
                <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
            <div class="invalid-feedback">Country name should be valid</div>

            </div>
        </div>

        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" placeholder="Mangalore, Karnataka" type="text" class="form-control" required>
            <div class="invalid-feedback">Enter your valid location</div>

        </div>

    <label class="form-label">Amenities</label>

    <label class="form-label">Amenities</label>
    <div class="brutal-amenity-grid mb-4">
        <% 
        const amenityIcons = {
            "WiFi": "fa-wifi", "Parking": "fa-car", "Pool": "fa-person-swimming",
            "Air Conditioning": "fa-snowflake", "Heating": "fa-fire", "Kitchen": "fa-utensils",
            "Washer": "fa-soap", "Dryer": "fa-wind", "Books & Reading Material": "fa-book",
            "Gym": "fa-dumbbell", "TV": "fa-tv", "Balcony": "fa-building",
            "Elevator": "fa-elevator", "Hot Tub": "fa-hot-tub-person", "BBQ Grill": "fa-stroopwafel",
            "Fireplace": "fa-fire-burner", "Outdoor Seating": "fa-chair", "Sound System": "fa-volume-high",
            "Workspace": "fa-briefcase", "Pet Friendly": "fa-paw", "Smoking Allowed": "fa-icicles",
            "Security Cameras": "fa-video", "Breakfast Included": "fa-bread-slice", "Private Entrance": "fa-door-open",
            "Wheelchair Accessible": "fa-wheelchair", "First Aid Kit": "fa-kit-medical", "Game Console": "fa-gamepad"
        };
        Object.entries(amenityIcons).forEach(([name, icon], i) => { %>
            <div class="amenity-item">
                <input type="checkbox" name="listing[amenities][]" value="<%= name %>" id="amenity-<%= i %>">
                <label class="amenity-label" for="amenity-<%= i %>">
                    <i class="fa-solid <%= icon %>"></i> <%= name %>
                </label>
            </div>
        <% }) %>
    </div>

        <div class="mb-4">
    <label class="form-label">Select Tags</label>
    <div class="d-flex flex-wrap gap-2">
        <% const tags = ["Trending", "Rooms", "Iconic Cities", "Mountains", "Castles", "Amazing Pools", "Campings", "Farms", "Arctic", "Domes"]; %>
        <% tags.forEach(tag => { %>
            <input type="checkbox" class="btn-check" name="listing[tags][]" value="<%= tag %>" id="<%= tag.replace(/\s+/g, '-') %>" autocomplete="off">
            <label class="btn " for="<%= tag.replace(/\s+/g, '-') %>"><%= tag %></label>
        <% }) %>
    </div>
</div>


            <button class="gradient-edit-btn ms-2 mt-3" type="submit">Publish Raw Listing</button>
            <br><br>
        </form>
        </div> <!-- brutal-form-container -->
        </div> <!-- col -->
    </div> <!-- row -->
</body>