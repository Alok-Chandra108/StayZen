<% layout("/layouts/boilerplate") %>

<!-- =================== EDIT LISTING PAGE =================== -->
<div class="nb-form-page">

  <div class="nb-form-wrapper">
    <div class="nb-form-card">

      <!-- Banner Header -->
      <div class="nb-form-card__banner">
        <div class="nb-form-card__banner-eyebrow">StayZen · Edit Mode</div>
        <h1 class="nb-form-card__banner-title">Edit Your<br>Listing</h1>
        <div class="nb-form-card__banner-sub">Update details for — <%= listing.title %></div>
      </div>

      <!-- Form -->
      <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" enctype="multipart/form-data" novalidate>
        <div class="nb-form-card__body">

          <!-- SECTION: Basic Info -->
          <div class="nb-form-section-divider nb-form-section-divider--accent">Basic Info</div>

          <!-- Title -->
          <div class="nb-form-group">
            <label class="nb-label" for="nb-edit-title">
              <span class="nb-step-number">1</span>
              Title
              <span class="nb-label__required"></span>
            </label>
            <input
              id="nb-edit-title"
              name="listing[title]"
              value="<%= listing.title %>"
              type="text"
              class="nb-input form-control"
              placeholder="Enter listing title"
              required>
            <div class="valid-feedback">Looks great!</div>
          </div>

          <!-- Description -->
          <div class="nb-form-group">
            <label class="nb-label" for="nb-edit-desc">
              <span class="nb-step-number">2</span>
              Description
              <span class="nb-label__required"></span>
            </label>
            <textarea
              id="nb-edit-desc"
              name="listing[description]"
              class="nb-textarea form-control"
              rows="5"
              required><%= listing.description %></textarea>
            <div class="invalid-feedback">A short description is required.</div>
          </div>

          <!-- SECTION: Media -->
          <div class="nb-form-section-divider">Media</div>

          <!-- Current Image Preview -->
          <div class="nb-current-image-block">
            <div class="nb-current-image-block__label">Current Listing Image</div>
            <img src="<%= originalImageUrl %>" alt="current listing image">
          </div>

          <!-- New Image Upload -->
          <div class="nb-form-group">
            <label class="nb-label" for="nb-edit-image">
              <span class="nb-step-number">3</span>
              Replace Image (optional)
            </label>
            <input
              id="nb-edit-image"
              name="listing[image]"
              type="file"
              class="nb-file-upload form-control"
              accept="image/*">
          </div>

          <!-- SECTION: Pricing & Location -->
          <div class="nb-form-section-divider">Pricing &amp; Location</div>

          <div class="nb-form-group nb-form-group--row">
            <!-- Price -->
            <div class="nb-form-group">
              <label class="nb-label" for="nb-edit-price">
                <span class="nb-step-number">4</span>
                Price / Night (₹)
                <span class="nb-label__required"></span>
              </label>
              <input
                id="nb-edit-price"
                name="listing[price]"
                value="<%= listing.price %>"
                type="number"
                class="nb-input form-control"
                min="0"
                required>
              <div class="invalid-feedback">Enter a valid price.</div>
            </div>

            <!-- Country -->
            <div class="nb-form-group">
              <label class="nb-label" for="nb-edit-country">
                <span class="nb-step-number">5</span>
                Country
                <span class="nb-label__required"></span>
              </label>
              <input
                id="nb-edit-country"
                name="listing[country]"
                value="<%= listing.country %>"
                type="text"
                class="nb-input form-control"
                required>
              <div class="invalid-feedback">Country name should be valid.</div>
            </div>
          </div>

          <!-- Location -->
          <div class="nb-form-group">
            <label class="nb-label" for="nb-edit-location">
              <span class="nb-step-number">6</span>
              Location / City
              <span class="nb-label__required"></span>
            </label>
            <input
              id="nb-edit-location"
              name="listing[location]"
              value="<%= listing.location %>"
              type="text"
              class="nb-input form-control"
              required>
            <div class="invalid-feedback">Enter your valid location.</div>
          </div>

          <!-- SECTION: Amenities -->
          <div class="nb-form-section-divider">Amenities</div>

          <div class="nb-form-group">
            <label class="nb-label">
              <span class="nb-step-number">7</span>
              Update amenities
            </label>
            <div class="nb-amenity-form-grid">
              <%
              const amenityIcons = {
                "WiFi": "fa-wifi", "Parking": "fa-car", "Pool": "fa-person-swimming",
                "Air Conditioning": "fa-snowflake", "Heating": "fa-fire", "Kitchen": "fa-utensils",
                "Washer": "fa-soap", "Dryer": "fa-wind", "Books & Reading Material": "fa-book",
                "Gym": "fa-dumbbell", "TV": "fa-tv", "Balcony": "fa-building",
                "Elevator": "fa-elevator", "Hot Tub": "fa-hot-tub-person", "BBQ Grill": "fa-stroopwafel",
                "Fireplace": "fa-fire-burner", "Outdoor Seating": "fa-chair", "Sound System": "fa-volume-high",
                "Workspace": "fa-briefcase", "Pet Friendly": "fa-paw", "Smoking Allowed": "fa-icicles",
                "Security Cameras": "fa-video", "Breakfast Included": "fa-bread-slice", "Private Entrance": "fa-door-open",
                "Wheelchair Accessible": "fa-wheelchair", "First Aid Kit": "fa-kit-medical", "Game Console": "fa-gamepad"
              };
              Object.entries(amenityIcons).forEach(([name, icon], i) => {
                const isChecked = listing.amenities && listing.amenities.includes(name);
              %>
                <div class="nb-amenity-form-item">
                  <input type="checkbox" name="listing[amenities][]" value="<%= name %>" id="amenity-<%= i %>" <%= isChecked ? 'checked' : '' %>>
                  <label class="nb-amenity-form-label" for="amenity-<%= i %>">
                    <i class="fa-solid <%= icon %>"></i> <%= name %>
                  </label>
                </div>
              <% }) %>
            </div>
          </div>

          <!-- SECTION: Tags -->
          <div class="nb-form-section-divider">Tags</div>

          <div class="nb-form-group">
            <label class="nb-label">
              <span class="nb-step-number">8</span>
              Update tags
            </label>
            <div class="nb-tags-form-group">
              <%
              const allTags = ["Trending","Rooms","Iconic Cities","Mountains","Castles","Amazing Pools","Campings","Farms","Arctic","Domes"];
              allTags.forEach((tag, i) => {
                const isSelected = listing.tags && listing.tags.includes(tag);
              %>
                <div class="nb-tag-form-item">
                  <input type="checkbox" name="listing[tags][]" value="<%= tag %>" id="tag-<%= i %>" autocomplete="off" <%= isSelected ? 'checked' : '' %>>
                  <label class="nb-tag-form-label" for="tag-<%= i %>"><%= tag %></label>
                </div>
              <% }); %>
            </div>
          </div>

        </div><!-- /nb-form-card__body -->

        <!-- Form Footer -->
        <div class="nb-form-footer">
          <a href="/listings/<%= listing._id %>" class="sz-btn" style="border-radius: 12px;">
            <i class="fa-solid fa-arrow-left me-2"></i>
            Cancel
          </a>
          <button class="sz-btn sz-btn--action" type="submit" style="width:auto; padding: 0.8rem 2.5rem; border-radius: 12px;">
            <i class="fa-solid fa-floppy-disk me-2"></i>
            Save Changes
          </button>
        </div>

      </form>
    </div><!-- /nb-form-card -->
  </div><!-- /nb-form-wrapper -->

</div><!-- /nb-form-page -->

<script src="/js/script.js"></script>