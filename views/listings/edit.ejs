    <% layout("/layouts/boilerplate") %>

    <body>
        <div class="row justify-content-center bg-brutal-dots py-5">
        <div class="col-10 col-md-8">
        <div class="brutal-form-container">
        <h3 class="mb-4" style="font-weight: 900; font-size: 2.5rem; text-transform: uppercase;">Edit your Listing</h3>
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" enctype="multipart/form-data" novalidate>
        <div class="mb-4">
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control border border-3 border-dark" style="box-shadow: inset 4px 4px 0px rgba(0,0,0,0.05);" required>
            <div class="valid-feedback">Looks Good</div>
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" required><%= listing.description %></textarea>
            <div class="invalid-feedback">A short description please</div>
        </div>

        <div class="mb-3">
            <p>Original Listing Image</p> <br>
            <img src="<%= originalImageUrl %>" alt="">
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">New Image Upload</label>
            <input name="listing[image]" type="file"   class="form-control"><br>
        </div>

        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input name="listing[price]" value="<%= listing.price %>"  type="number" class="form-control" required>
                <div class="invalid-feedback">Enter the valid Price</div>
            </div>
        
            <div class="mb-3 col-md-8">
                <label for="Country" class="form-label">Country</label>
                <input name="listing[country]" value="<%= listing.country %>"  type="text" class="form-control" required>
                <div class="invalid-feedback">Country name should be valid</div>
            </div>
        </div>

        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" value="<%= listing.location %>"  type="text" class="form-control" required>
            <div class="invalid-feedback">Enter your valid location</div>
        </div>

        <div class="mb-3">
    <label class="form-label">Amenities</label>
    <div class="brutal-amenity-grid mb-4">
        <% 
        const amenityIcons = {
            "WiFi": "fa-wifi", "Parking": "fa-car", "Pool": "fa-person-swimming",
            "Air Conditioning": "fa-snowflake", "Heating": "fa-fire", "Kitchen": "fa-utensils",
            "Washer": "fa-soap", "Dryer": "fa-wind", "Books & Reading Material": "fa-book",
            "Gym": "fa-dumbbell", "TV": "fa-tv", "Balcony": "fa-building",
            "Elevator": "fa-elevator", "Hot Tub": "fa-hot-tub-person", "BBQ Grill": "fa-stroopwafel",
            "Fireplace": "fa-fire-burner", "Outdoor Seating": "fa-chair", "Sound System": "fa-volume-high",
            "Workspace": "fa-briefcase", "Pet Friendly": "fa-paw", "Smoking Allowed": "fa-icicles",
            "Security Cameras": "fa-video", "Breakfast Included": "fa-bread-slice", "Private Entrance": "fa-door-open",
            "Wheelchair Accessible": "fa-wheelchair", "First Aid Kit": "fa-kit-medical", "Game Console": "fa-gamepad"
        };
        Object.entries(amenityIcons).forEach(([name, icon], i) => { 
            const isChecked = listing.amenities && listing.amenities.includes(name);
        %>
            <div class="amenity-item">
                <input type="checkbox" name="listing[amenities][]" value="<%= name %>" id="amenity-<%= i %>" <%= isChecked ? 'checked' : '' %>>
                <label class="amenity-label" for="amenity-<%= i %>">
                    <i class="fa-solid <%= icon %>"></i> <%= name %>
                </label>
            </div>
        <% }) %>
    </div>

    </div>
    <div class="mb-3">
  <label class="form-label">Tags</label>
  <div class="d-flex flex-wrap gap-2">
    <% 
    const allTags = ["Trending","Rooms","Iconic Cities","Mountains","Castles","Amazing Pools","Campings","Farms","Arctic","Domes"];
    allTags.forEach((tag, i) => {
      const isSelected = listing.tags && listing.tags.includes(tag);
    %>
      <input type="checkbox" class="btn-check" name="listing[tags][]" value="<%= tag %>" id="tag-<%= i %>" autocomplete="off" <%= isSelected ? 'checked' : '' %> >
      <label class="btn btn-outline-dark" for="tag-<%= i %>"><%= tag %></label>
    <% }); %>
  </div>
</div>

            <button class="gradient-edit-btn me-2 mt-3">Update Raw Listing</button>
            <br><br><br>
        </form>
        </div><!-- container -->
        </div><!-- col -->
        </div><!-- row -->
    <script src="/js/script.js"></script>
    </body>