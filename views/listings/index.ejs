<% layout("/layouts/boilerplate") -%>

<!-- ================================================================
     STAYZEN — LISTINGS INDEX PAGE
     ================================================================ -->

<!-- ── HERO SECTION ── -->
<section class="sz-hero" aria-label="Hero banner">

  <!-- Left — text block -->
  <div class="sz-hero__left">

    <!-- Eyebrow label -->
    <div class="sz-hero__eyebrow">
      <span class="sz-hero__eyebrow-dot"></span>
      Premium Stays & Unique Properties
    </div>

    <!-- Main headline -->
    <h1 class="sz-hero__heading hero-gsap-text">
      Discover Your<br>Perfect Stay.
    </h1>

    <!-- Sub copy -->
    <p class="sz-hero__sub">
      Handpicked properties, exceptional experiences. Find your ideal getaway from boutique villas to mountain retreats.
    </p>

    <!-- CTA row -->
    <div class="sz-hero__ctas">
      <a href="#listing-container" class="sz-cta-primary">
        Explore Properties
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="/listings/new" class="sz-cta-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        List Your Property
      </a>
    </div>

    <!-- Stats row -->
    <div class="sz-hero__stats">
      <div class="sz-stat">
        <span class="sz-stat__num">500+</span>
        <span class="sz-stat__label">Properties</span>
      </div>
      <div class="sz-stat-divider"></div>
      <div class="sz-stat">
        <span class="sz-stat__num">50+</span>
        <span class="sz-stat__label">Destinations</span>
      </div>
      <div class="sz-stat-divider"></div>
      <div class="sz-stat">
        <span class="sz-stat__num">10k+</span>
        <span class="sz-stat__label">Happy Guests</span>
      </div>
    </div>
  </div>

</section>

<!-- ── FILTER ROW ── -->
<div class="sz-filter-section">
  <div class="sz-filter-label">Browse by</div>

  <!-- TAX TOGGLE -->
  <div class="sz-tax-toggle-wrapper">
    <div class="sz-tax-toggle-box">
      <span class="sz-tax-label">Show total taxes</span>
      <label class="sz-switch">
        <input type="checkbox" id="tax-toggle" name="tax-toggle">
        <span class="sz-slider"></span>
      </label>
    </div>
  </div>
  <!-- DATE RANGE AVAILABILITY FILTER -->
  <div class="sz-date-filter-wrapper">
    <div class="sz-date-filter-box">
      <i class="fa-regular fa-calendar" aria-hidden="true"></i>
      <input type="text" id="avail-checkin" name="checkin" class="sz-date-filter-input" placeholder="Check-in" readonly>
      <span class="sz-date-filter-arrow">→</span>
      <input type="text" id="avail-checkout" name="checkout" class="sz-date-filter-input" placeholder="Check-out" readonly>
      <button type="button" id="avail-clear" class="sz-date-filter-clear" title="Clear dates" style="display:none;">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
  </div>

  <div id="filters">
    <div class="filter" data-tag="Trending">
      <i class="fa-solid fa-fire"></i><p>Trending</p>
    </div>
    <div class="filter" data-tag="Rooms">
      <i class="fa-solid fa-bed"></i><p>Rooms</p>
    </div>
    <div class="filter" data-tag="Iconic Cities">
      <i class="fa-solid fa-gopuram"></i><p>Iconic Cities</p>
    </div>
    <div class="filter" data-tag="Mountains">
      <i class="fa-solid fa-mountain"></i><p>Mountains</p>
    </div>
    <div class="filter" data-tag="Castles">
      <i class="fa-brands fa-fort-awesome"></i><p>Castles</p>
    </div>
    <div class="filter" data-tag="Amazing Pools">
      <i class="fa-solid fa-water-ladder"></i><p>Pools</p>
    </div>
    <div class="filter" data-tag="Campings">
      <i class="fa-solid fa-campground"></i><p>Campings</p>
    </div>
    <div class="filter" data-tag="Farms">
      <i class="fa-solid fa-cow"></i><p>Farms</p>
    </div>
    <div class="filter" data-tag="Arctic">
      <i class="fa-solid fa-snowflake"></i><p>Arctic</p>
    </div>
    <div class="filter" data-tag="Domes">
      <i class="fa-solid fa-igloo"></i><p>Domes</p>
    </div>
  </div>
</div>

<!-- ── NO MATCH ── -->
<div class="no-match-container text-center mt-5 pt-5 position-relative" style="display: none; min-height: 200px;">
  <div style="position: relative; z-index: 2;">
    <div style="font-size: 3rem; margin-bottom: 1rem;">🔍</div>
    <h4 style="font-weight: 700; color: var(--navy);">No matches found</h4>
    <p style="color: var(--text-light); font-weight: 400;">Try a different keyword or filter.</p>
  </div>
</div>

<!-- ── SECTION HEADER ── -->
<div class="sz-listings-header">
  <div class="sz-listings-header__left">
    <div class="sz-listings-header__eyebrow">All Properties</div>
    <h2 class="sz-listings-header__title">Featured Stays</h2>
  </div>
  <div class="sz-listings-header__right"></div>
</div>

<!-- ── GLOBAL INTERACTIVE MAP ── -->
<div class="sz-global-map-container my-4" style="padding: 0 2rem;">
  <div id="global-map" style="height: 450px; width: 100%; border: 1px solid var(--border-color); border-radius: 16px; position: relative; z-index: 1; box-shadow: 0 4px 16px rgba(0,0,0,0.08);"></div>
</div>

<!-- ── LISTING GRID ── -->
<div id="listing-container" class="sz-listing-grid">
  <% for(let listing of allListings){ %>
    <a href="/listings/<%= listing._id %>" class="list-link sz-card-link">
      <article class="listing-card sz-listing-card" data-id="<%= listing._id %>" data-tags='<%= JSON.stringify(listing.tags || []) %>' data-lat="<%= (listing.geometry && listing.geometry.coordinates) ? listing.geometry.coordinates[1] : 0 %>" data-lng="<%= (listing.geometry && listing.geometry.coordinates) ? listing.geometry.coordinates[0] : 0 %>" data-price="<%= listing.price %>" data-title="<%= listing.title %>" data-url="/listings/<%= listing._id %>">

        <!-- Image section -->
        <div class="image-wrapper sz-card__img-wrap">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" data-flip-id="img-<%= listing._id %>">
          <!-- Hover overlay -->
          <div class="sz-card__overlay">
            <span class="sz-card__overlay-text">View Details →</span>
          </div>
          <!-- Corner badge -->
          <% if (listing.tags && listing.tags.length > 0) { %>
            <div class="sz-card__tag-badge"><%= listing.tags[0] %></div>
          <% } %>
        </div>

        <!-- Body -->
        <div class="card-body sz-card__body">
          <p class="card-text">
            <b><%= listing.title %></b>
            <span class="card-price-tag">
              ₹ <%= listing.price.toLocaleString("en-IN") %> / night
              <span class="tax-info" style="display: none;"> &nbsp; +18% GST (₹ <%= (listing.price * 0.18).toLocaleString("en-IN") %>)</span>
            </span>
            <span class="description-clamp"><%= listing.description %></span>
          </p>
          <!-- Location -->
          <div class="sz-card__location">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            <%= listing.location %>, <%= listing.country %>
          </div>
        </div>

      </article>
    </a>
  <% } %>
</div>

<script src="/js/script.js"></script>
