    </a>
    
    <% if (!currUser) { %>
      <a href="/signup" class="nb-nav-link nb-nav-link--pink">
        <i class="fa-solid fa-user-plus"></i> Sign Up
      </a>
      <a href="/login" class="nb-nav-link nb-nav-link--coral">
        <i class="fa-solid fa-right-to-bracket"></i> Login
      </a>
    <% } else { %>
      <a href="/logout" class="nb-nav-link nb-nav-link--coral">
        <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
      </a>
    <% } %>
