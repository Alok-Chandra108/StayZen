<% layout("/layouts/boilerplate") %>

<!-- ================================================================
     STAYZEN — SIGNUP PAGE / NEU-BRUTALISM × AWWWARDS
     ================================================================ -->
<div class="sz-auth-page">

  <!-- Left Panel — Illustration -->
  <div class="sz-auth-left" aria-hidden="true">
    <svg class="sz-auth-bg-svg" viewBox="0 0 400 600" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="auth-lines" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
          <line x1="0" y1="0" x2="24" y2="24" stroke="rgba(10,10,10,0.15)" stroke-width="1.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#auth-lines)"/>

      <!-- Big number -->
      <text x="200" y="220" text-anchor="middle" font-family="Space Grotesk" font-weight="900" font-size="180" fill="#0A0A0A" opacity="0.06">01</text>

      <!-- Shapes -->
      <rect x="50" y="60" width="180" height="70" fill="#FFE500" stroke="#0A0A0A" stroke-width="5"/>
      <text x="140" y="104" text-anchor="middle" font-family="Space Grotesk" font-weight="900" font-size="26" fill="#0A0A0A">JOIN US!</text>

      <circle cx="310" cy="180" r="70" fill="#C8FF00" stroke="#0A0A0A" stroke-width="5"/>
      <line x1="310" y1="110" x2="310" y2="250" stroke="#0A0A0A" stroke-width="3"/>
      <line x1="240" y1="180" x2="380" y2="180" stroke="#0A0A0A" stroke-width="3"/>

      <polygon points="100,340 180,280 260,340 240,420 120,420" fill="#FF4D2E" stroke="#0A0A0A" stroke-width="5"/>

      <rect x="240" y="400" width="110" height="110" fill="none" stroke="#7C6AF7" stroke-width="5" stroke-dasharray="12 8"/>
      <rect x="255" y="415" width="80" height="80" fill="#7C6AF7" stroke="#0A0A0A" stroke-width="4"/>
    </svg>

    <div class="sz-auth-left__text">
      <div class="sz-auth-left__eyebrow">New Here?</div>
      <div class="sz-auth-left__big">JOIN<br>THE<br>ZEN.</div>
      <div class="sz-auth-left__small">Create an account to list your space or book your next raw escape.</div>
    </div>
  </div>

  <!-- Right Panel — Form -->
  <div class="sz-auth-right">
    <div class="sz-auth-form-card">

      <div class="sz-auth-form-card__header" style="background: var(--coral);">
        <div class="sz-auth-form-card__eyebrow">Create Account</div>
        <h1 class="sz-auth-form-card__title">Sign Up<br>Free</h1>
      </div>

      <div class="sz-auth-form-card__body">
        <form action="/signup" method="post" class="needs-validation" novalidate>

          <div class="sz-auth-field">
            <label for="username" class="sz-auth-label">
              <span class="sz-auth-step" style="background: var(--lavender);">1</span> Username
            </label>
            <input
              name="username"
              id="username"
              type="text"
              class="sz-auth-input"
              placeholder="Choose a username"
              required
              autocomplete="username"
            >
          </div>

          <div class="sz-auth-field">
            <label for="email" class="sz-auth-label">
              <span class="sz-auth-step" style="background: var(--lavender);">2</span> Email
            </label>
            <input
              name="email"
              id="email"
              type="email"
              class="sz-auth-input"
              placeholder="you@example.com"
              required
              autocomplete="email"
            >
          </div>

          <div class="sz-auth-field">
            <label for="password" class="sz-auth-label">
              <span class="sz-auth-step" style="background: var(--lavender);">3</span> Password
            </label>
            <input
              name="password"
              id="password"
              type="password"
              class="sz-auth-input"
              placeholder="••••••••"
              required
              autocomplete="new-password"
            >
          </div>

          <button class="sz-auth-submit" type="submit" style="box-shadow: 6px 6px 0 var(--lavender);">
            <i class="fa-solid fa-user-plus me-2" aria-hidden="true"></i>
            Create Account
          </button>

        </form>

        <div class="sz-auth-switch">
          Already have an account? <a href="/login">Log in →</a>
        </div>
      </div>

    </div>
  </div>

</div>