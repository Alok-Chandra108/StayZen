<% layout("/layouts/boilerplate") %>

<!-- ================================================================
     STAYZEN — SIGNUP PAGE (REDESIGNED)
     ================================================================ -->
<div class="sz-auth-page">

  <!-- Left Panel — Illustration -->
  <div class="sz-auth-left" aria-hidden="true">
    <svg class="sz-auth-bg-svg" viewBox="0 0 400 600" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="auth-grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(10,10,10,0.08)" stroke-width="1.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#auth-grid)"/>

      <!-- Accent elements -->
      <circle cx="200" cy="200" r="140" fill="none" stroke="#FFE500" stroke-width="60" opacity="0.1"/>
      
      <!-- Big branding -->
      <text x="50" y="150" font-family="Space Grotesk" font-weight="900" font-size="64" fill="#0A0A0A" opacity="0.05">STAY</text>
      <text x="50" y="220" font-family="Space Grotesk" font-weight="900" font-size="64" fill="#0A0A0A" opacity="0.05">ZEN</text>

      <rect x="60" y="280" width="280" height="150" fill="#FFE500" stroke="#0A0A0A" stroke-width="6"/>
      <rect x="80" y="300" width="280" height="150" fill="none" stroke="#0A0A0A" stroke-width="2" stroke-dasharray="10 5"/>
      <text x="200" y="365" text-anchor="middle" font-family="Space Grotesk" font-weight="900" font-size="42" fill="#0A0A0A">CREATE.</text>
    </svg>

    <div class="sz-auth-left__text">
      <div class="sz-auth-left__eyebrow">The Collective</div>
      <div class="sz-auth-left__big">JOIN<br>US.</div>
      <div class="sz-auth-left__small">Your adventure starts with a single step. Verify your email to unlock premium stays.</div>
    </div>
  </div>

  <!-- Right Panel — Form -->
  <div class="sz-auth-right">
    <div class="sz-auth-form-card">

      <div class="sz-auth-form-card__header" style="background: var(--ink);">
        <div class="sz-auth-form-card__eyebrow" style="color: var(--yellow);">Begin Journey</div>
        <h1 class="sz-auth-form-card__title" style="color: var(--white);">Member<br>Registry</h1>
      </div>

      <div class="sz-auth-form-card__body">
        <form action="/signup" method="post" class="needs-validation" novalidate>

          <div class="sz-auth-field">
            <label for="username" class="sz-auth-label">
              <span class="sz-auth-step">1</span> Display Name
            </label>
            <input
              name="username"
              id="username"
              type="text"
              class="sz-auth-input"
              placeholder="How should we call you?"
              required
              autocomplete="username"
            >
            <div class="invalid-feedback">Please choose a display name.</div>
          </div>

          <div class="sz-auth-field">
            <label for="email" class="sz-auth-label">
              <span class="sz-auth-step">2</span> Email Address
            </label>
            <input
              name="email"
              id="email"
              type="email"
              class="sz-auth-input"
              placeholder="you@domain.com"
              required
              autocomplete="email"
            >
            <div class="invalid-feedback">A valid email is required.</div>
          </div>

          <div class="sz-auth-field">
            <label for="password" class="sz-auth-label">
              <span class="sz-auth-step">3</span> Security Key
            </label>
            <input
              name="password"
              id="password"
              type="password"
              class="sz-auth-input"
              placeholder="Minimum 8 characters"
              required
              autocomplete="new-password"
            >
            <div class="invalid-feedback">Password is required.</div>
          </div>

          <button class="sz-auth-submit sz-auth-submit--signup" type="submit">
            <span class="btn-text">Send Verification Code</span>
            <i class="fa-solid fa-arrow-right ms-2"></i>
          </button>

          <div class="sz-auth-divider">
            <span>OR PROCEED WITH</span>
          </div>

          <a href="/auth/google" class="sz-auth-google">
            <i class="fa-brands fa-google"></i>
            <span>Register with Google</span>
          </a>
        </form>

        <div class="sz-auth-switch">
          Registered before? <a href="/login">Sign In Instead →</a>
        </div>
      </div>
    </div>
  </div>
</div>