<% layout("/layouts/boilerplate") %>

<!-- ================================================================
     STAYZEN — SIGNUP PAGE
     ================================================================ -->
<div class="sz-auth-page">

  <!-- Left Panel -->
  <div class="sz-auth-left" aria-hidden="true">
    <div class="sz-auth-left__text">
      <div class="sz-auth-left__eyebrow">Join StayZen</div>
      <div class="sz-auth-left__big">Create<br>Account.</div>
      <div class="sz-auth-left__small">Your next getaway starts here. Create your account to discover premium stays worldwide.</div>
    </div>
  </div>

  <!-- Right Panel — Form -->
  <div class="sz-auth-right">
    <div class="sz-auth-form-card">

      <div class="sz-auth-form-card__header">
        <div class="sz-auth-form-card__eyebrow">Get Started</div>
        <h1 class="sz-auth-form-card__title">Create<br>Account</h1>
      </div>

      <div class="sz-auth-form-card__body">
        <form action="/signup" method="post" class="needs-validation" novalidate>

          <div class="sz-auth-field">
            <label for="username" class="sz-auth-label">
              <span class="sz-auth-step">1</span> Full Name
            </label>
            <input
              name="username"
              id="username"
              type="text"
              class="sz-auth-input"
              placeholder="How should we call you?"
              required
              autocomplete="username"
            >
            <div class="invalid-feedback">Please choose a display name.</div>
          </div>

          <div class="sz-auth-field">
            <label for="email" class="sz-auth-label">
              <span class="sz-auth-step">2</span> Email Address
            </label>
            <input
              name="email"
              id="email"
              type="email"
              class="sz-auth-input"
              placeholder="you@domain.com"
              required
              autocomplete="email"
            >
            <div class="invalid-feedback">A valid email is required.</div>
          </div>

          <div class="sz-auth-field">
            <label for="password" class="sz-auth-label">
              <span class="sz-auth-step">3</span> Password
            </label>
            <input
              name="password"
              id="password"
              type="password"
              class="sz-auth-input"
              placeholder="Minimum 8 characters"
              required
              autocomplete="new-password"
            >
            <div class="invalid-feedback">Password is required.</div>
          </div>

          <button class="sz-auth-submit sz-auth-submit--signup" type="submit">
            <span class="btn-text">Send Verification Code</span>
            <i class="fa-solid fa-arrow-right ms-2"></i>
          </button>

          <div class="sz-auth-divider">
            <span>OR</span>
          </div>

          <a href="/auth/google" class="sz-auth-google">
            <i class="fa-brands fa-google"></i>
            <span>Sign up with Google</span>
          </a>
        </form>

        <div class="sz-auth-switch">
          Already have an account? <a href="/login">Sign In →</a>
        </div>
      </div>
    </div>
  </div>
</div>