<%- layout("/layouts/boilerplate") -%>

  <main class="sz-dashboard">
    <div class="container">

      <header class="sz-dashboard__header">
        <h1 class="sz-dashboard__title">
          <i class="fa-solid fa-suitcase-rolling me-3"></i>My Bookings
        </h1>
        <div class="sz-badge sz-badge--action">
          <%= passes.length %> Confirmed
        </div>
      </header>

      <% if(passes.length===0) { %>
        <div class="sz-dashboard__empty">
          <i class="fa-solid fa-suitcase"></i>
          <h2 class="sz-dashboard__title" style="font-size: 1.5rem; margin-top: 1rem;">No Bookings Yet</h2>
          <p style="margin: 1.5rem auto; color: var(--text-light); max-width: 400px;">You haven't booked any stays yet. Explore our properties to find your perfect getaway.</p>

          <a href="/listings" class="sz-btn sz-btn--action" style="border-radius: 9999px;">Explore Properties</a>

        </div>
        <% } else { %>
          <div class="sz-pass-grid">
            <% passes.forEach((pass)=> { %>
              <article class="sz-pass-ticket">
                <% let statusClass='sz-pass-ticket__status--pending' ; if (!pass.status || pass.status==='Confirmed' ) {
                  statusClass='sz-pass-ticket__status--confirmed' ; } else if (pass.status==='Declined' ) {
                  statusClass='sz-pass-ticket__status--declined' ; } %>
                  <div class="sz-pass-ticket__img-wrap">
                    <img src="<%= pass.listing.image.url %>" alt="<%= pass.listing.title %>">
                    <div class="sz-pass-ticket__status sz-pass-ticket__status--confirmed">
                      Confirmed
                    </div>
                  </div>

                  <div class="sz-pass-ticket__content">
                    <h2 class="sz-pass-ticket__title">
                      <%= pass.listing.title %>
                    </h2>
                    <div class="sz-pass-ticket__loc">
                      <i class="fa-solid fa-location-dot"></i>
                      <%= pass.listing.location %>
                    </div>

                    <div class="sz-pass-ticket__data">
                      <div class="sz-pass-ticket__row">
                        <span class="sz-pass-ticket__label">Check-in</span>

                        <span class="sz-pass-ticket__val">
                          <%= pass.checkIn.toLocaleDateString('en-GB', { day: '2-digit' , month: 'short' ,
                            year: 'numeric' }) %>
                        </span>
                      </div>
                      <div class="sz-pass-ticket__row">
                        <span class="sz-pass-ticket__label">Check-out</span>

                        <span class="sz-pass-ticket__val">
                          <%= pass.checkOut.toLocaleDateString('en-GB', { day: '2-digit' , month: 'short' ,
                            year: 'numeric' }) %>
                        </span>
                      </div>
                      <div class="sz-pass-ticket__row sz-pass-ticket__total">
                        <span class="sz-pass-ticket__label" style="color: var(--navy); font-weight: 700;">Total</span>

                        <span class="sz-pass-ticket__val" style="color: var(--navy); font-size: 1.1rem; font-weight: 700;">₹<%=
                            pass.totalPrice.toLocaleString("en-IN") %></span>
                      </div>
                    </div>
                  </div>

                  <footer class="sz-pass-ticket__footer"
                    style="display: flex; justify-content: space-between; align-items: center;">
                    <a href="/listings/<%= pass.listing._id %>" class="sz-pass-ticket__link">
                      View Details <i class="fa-solid fa-arrow-right ms-2"></i>
                    </a>
                    <a href="/dashboard/bookings/<%= pass._id %>/pass" class="sz-btn sz-btn--action"
                      style="font-size: 0.75rem; padding: 6px 14px; border-radius: 9999px;">
                      <i class="fa-solid fa-download me-1"></i> Download
                    </a>
                  </footer>
              </article>
              <% }) %>
          </div>
          <% } %>
    </div>
  </main>