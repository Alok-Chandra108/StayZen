<%- layout("/layouts/boilerplate") -%>

<div class="nb-page-wrapper py-5">
  <div class="container" style="max-width: 1200px;">
    
    <div class="d-flex justify-content-between align-items-center mb-5" style="border-bottom: 4px solid var(--ink); padding-bottom: 1rem;">
      <h1 style="font-family: var(--font-display); font-weight: 900; text-transform: uppercase; font-size: 3rem; margin: 0; color: var(--ink);">
        <i class="fa-solid fa-ticket me-3" style="color: var(--coral);"></i>MY PASSES
      </h1>
      <span class="nb-badge" style="background: var(--ink); color: var(--cream);">
        <%= passes.length %> SECURED
      </span>
    </div>

    <% if(passes.length === 0) { %>
      <div class="sz-alert-box text-center p-5" style="background: var(--white); border: 4px solid var(--ink); box-shadow: 10px 10px 0 var(--coral);">
        <i class="fa-solid fa-ghost mb-3" style="font-size: 4rem; color: var(--ink); opacity: 0.5;"></i>
        <h2 style="font-family: var(--font-display); font-weight: 900; text-transform: uppercase;">NO PASSES SECURED YET</h2>
        <p style="font-weight: 500; font-size: 1.1rem; color: #555;">You haven't claimed any territory. Browse the grid and secure your next base.</p>
        <a href="/listings" class="sz-btn sz-btn--action mt-3" style="color: white; text-decoration: none;">EXPLORE GRID</a>
      </div>
    <% } else { %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% passes.forEach((pass) => { %>
          <div class="col">
            <div class="card h-100" style="border: 4px solid var(--ink); border-radius: 0; box-shadow: 8px 8px 0 var(--yellow); overflow: hidden; transition: transform 0.1s;">
              
              <div style="position: relative; height: 200px; border-bottom: 4px solid var(--ink);">
                <img src="<%= pass.listing.image.url %>" class="card-img-top" alt="<%= pass.listing.title %>" style="height: 100%; object-fit: cover; filter: grayscale(0.2) contrast(1.1);">
                <div style="position: absolute; top: 10px; right: 10px; background: var(--acid); padding: 5px 10px; border: 2px solid var(--ink); font-weight: 900; font-size: 0.8rem;">
                  CONFIRMED
                </div>
              </div>
              
              <div class="card-body" style="background: var(--cream); padding: 1.5rem;">
                <h5 class="card-title" style="font-family: var(--font-display); font-weight: 900; text-transform: uppercase; font-size: 1.3rem; margin-bottom: 1rem; line-height: 1.1;">
                  <%= pass.listing.title %>
                </h5>
                <p class="card-text mb-2" style="font-weight: 800; font-size: 0.85rem; color: #555;">
                  <i class="fa-solid fa-location-dot me-2 text-danger"></i><%= pass.listing.location %>
                </p>
                
                <div class="mt-3 p-3" style="background: var(--white); border: 2px dashed var(--ink);">
                  <div class="d-flex justify-content-between mb-2">
                    <span style="font-weight: 800; font-size: 0.75rem;">INFILTRATION:</span>
                    <strong style="font-weight: 900;"><%= pass.checkIn.toLocaleDateString('en-GB') %></strong>
                  </div>
                  <div class="d-flex justify-content-between mb-2">
                    <span style="font-weight: 800; font-size: 0.75rem;">EXTRACTION:</span>
                    <strong style="font-weight: 900;"><%= pass.checkOut.toLocaleDateString('en-GB') %></strong>
                  </div>
                  <div class="d-flex justify-content-between border-top border-dark pt-2 mt-2">
                    <span style="font-weight: 800; font-size: 0.75rem; color: var(--coral);">TOTAL:</span>
                    <strong style="font-weight: 900; color: var(--coral);">₹<%= pass.totalPrice.toLocaleString("en-IN") %></strong>
                  </div>
                </div>
              </div>
              
              <div class="card-footer p-0" style="border-top: 4px solid var(--ink); background: var(--lavender);">
                <a href="/listings/<%= pass.listing._id %>" class="d-block w-100 text-center p-3 text-white text-decoration-none" style="font-family: var(--font-display); font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">
                  VIEW INTEL <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
              </div>
              
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<style>
.card:hover {
  transform: translate(3px, 3px);
  box-shadow: 5px 5px 0 var(--yellow) !important;
}
</style>
