<% layout("/layouts/boilerplate") %>

<!-- ================================================================
     STAYZEN — OTP VERIFICATION PAGE
     ================================================================ -->
<div class="sz-auth-page">

  <!-- Left Panel -->
  <div class="sz-auth-left" aria-hidden="true">
    <div class="sz-auth-left__text">
      <div class="sz-auth-left__eyebrow">Verification</div>
      <div class="sz-auth-left__big">Verify<br>Email.</div>
      <div class="sz-auth-left__small">We've sent a 6-digit code to your inbox. Enter it below to complete your registration.</div>
    </div>
  </div>

  <!-- Right Panel — Form -->
  <div class="sz-auth-right">
    <div class="sz-auth-form-card">

      <div class="sz-auth-form-card__header" style="background: var(--navy);">
        <div class="sz-auth-form-card__eyebrow">Final Step</div>
        <h1 class="sz-auth-form-card__title">Verify<br>Email</h1>
      </div>

      <div class="sz-auth-form-card__body">
        <p class="mb-4" style="color: var(--text-light); font-size: 0.9rem;">A verification code was sent to <strong style="color: var(--navy);"><%= email %></strong></p>

        <form action="/verify-otp" method="post" class="needs-validation" novalidate>
          <input type="hidden" name="email" value="<%= email %>">

          <div class="sz-auth-field">
            <label for="otp" class="sz-auth-label">
              6-Digit Verification Code
            </label>
            <input
              name="otp"
              id="otp"
              type="text"
              class="sz-auth-input sz-auth-input--otp"
              placeholder="000000"
              required
              maxlength="6"
              pattern="\d{6}"
              inputmode="numeric"
              autocomplete="one-time-code"
            >
            <div class="invalid-feedback">Please enter the 6-digit code.</div>
          </div>

          <button class="sz-auth-submit" type="submit">
            <span class="btn-text">Verify & Create Account</span>
            <i class="fa-solid fa-circle-check ms-2"></i>
          </button>
        </form>

        <div class="sz-auth-switch mt-4">
          Didn't receive a code? 
          <form action="/resend-otp" method="post" class="d-inline">
            <input type="hidden" name="email" value="<%= email %>">
            <button type="submit" class="btn btn-link p-0 text-decoration-none" style="font-weight: 600; color: var(--navy);">Resend Code</button>
          </form>
        </div>
        
        <div class="sz-auth-switch mt-2">
            Wrong email? <a href="/signup">Start Over →</a>
        </div>
      </div>

    </div>
  </div>

</div>
