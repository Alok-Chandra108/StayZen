<% layout("/layouts/boilerplate") %>

<!-- ================================================================
     STAYZEN — OTP VERIFICATION PAGE
     ================================================================ -->
<div class="sz-auth-page">

  <!-- Left Panel — Illustration -->
  <div class="sz-auth-left" aria-hidden="true">
    <svg class="sz-auth-bg-svg" viewBox="0 0 400 600" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="verify-dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="10" cy="10" r="1" fill="rgba(10,10,10,0.3)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#verify-dots)"/>

      <rect x="50" y="200" width="300" height="200" fill="#FFE500" stroke="#0A0A0A" stroke-width="6"/>
      <path d="M 50 200 L 200 300 L 350 200" fill="none" stroke="#0A0A0A" stroke-width="4"/>
      
      <text x="200" y="460" text-anchor="middle" font-family="Space Grotesk" font-weight="900" font-size="42" fill="#0A0A0A">VERIFY.</text>
    </svg>

    <div class="sz-auth-left__text">
      <div class="sz-auth-left__eyebrow">Identity Check</div>
      <div class="sz-auth-left__big">SECURE<br>AUTH.</div>
      <div class="sz-auth-left__small">We have sent a 6-digit code to your inbox. Enter it below to finalize your membership.</div>
    </div>
  </div>

  <!-- Right Panel — Form -->
  <div class="sz-auth-right">
    <div class="sz-auth-form-card">

      <div class="sz-auth-form-card__header" style="background: var(--lavender);">
        <div class="sz-auth-form-card__eyebrow" style="color: var(--ink);">Final Phase</div>
        <h1 class="sz-auth-form-card__title">Verify<br>Identity</h1>
      </div>

      <div class="sz-auth-form-card__body">
        <p class="mb-4 text-muted">A code was sent to <strong><%= email %></strong></p>

        <form action="/verify-otp" method="post" class="needs-validation" novalidate>
          <input type="hidden" name="email" value="<%= email %>">

          <div class="sz-auth-field">
            <label for="otp" class="sz-auth-label">
              6-Digit Verification Code
            </label>
            <input
              name="otp"
              id="otp"
              type="text"
              class="sz-auth-input sz-auth-input--otp"
              placeholder="000000"
              required
              maxlength="6"
              pattern="\d{6}"
              inputmode="numeric"
              autocomplete="one-time-code"
            >
            <div class="invalid-feedback">Please enter the 6-digit code.</div>
          </div>

          <button class="sz-auth-submit" type="submit">
            <span class="btn-text">Verify & Activate Account</span>
            <i class="fa-solid fa-circle-check ms-2"></i>
          </button>
        </form>

        <div class="sz-auth-switch mt-4">
          Didn't receive a code? 
          <form action="/resend-otp" method="post" class="d-inline">
            <input type="hidden" name="email" value="<%= email %>">
            <button type="submit" class="btn btn-link p-0 text-decoration-none" style="font-weight: 700; color: var(--ink);">Resend Code</button>
          </form>
        </div>
        
        <div class="sz-auth-switch mt-2">
            Incorrect email? <a href="/signup">Start Over →</a>
        </div>
      </div>

    </div>
  </div>

</div>

<style>
.sz-auth-input--otp {
    text-align: center;
    font-size: 2.5rem !important;
    letter-spacing: 0.8rem;
    font-weight: 900;
}
</style>
