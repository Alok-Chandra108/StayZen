<%- layout("/layouts/boilerplate") -%>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<main class="sz-dashboard">
  <div class="container">
    
    <header class="sz-dashboard__header">
      <h1 class="sz-dashboard__title" style="flex: 1;">
        <i class="fa-solid fa-chess-rook me-3"></i>HOST DASHBOARD
      </h1>
      <div class="sz-badge sz-badge--action" style="background: var(--lime); color: var(--ink);">
        <%= listings.length %> LISTINGS
      </div>
    </header>


    <% 
      // Extract query parameters safely
      const q = locals.searchQuery || {}; 
    %>

    <!-- SUMMARY METRICS & FILTERS -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 4rem; align-items: start;">
      
      <!-- Earnings Card -->
      <div style="background: var(--coral); color: var(--white); padding: 2.5rem; border: 4px solid var(--ink); box-shadow: 10px 10px 0 var(--ink); position: relative; overflow: hidden;">
        <div style="font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 0.5rem; opacity: 0.9;">Total Simulated Yield</div>
        <div style="font-family: var(--font-h); font-size: 3.5rem; font-weight: 900; line-height: 1;">₹<%= totalEarnings.toLocaleString("en-IN") %></div>
        <% if(q.startDate || q.endDate) { %>
          <div style="margin-top: 1rem; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; background: rgba(0,0,0,0.2); display: inline-block; padding: 2px 8px;">Filtered View</div>
        <% } %>
        <i class="fa-solid fa-chart-line" style="position: absolute; bottom: -10px; right: -10px; font-size: 6rem; opacity: 0.1;"></i>
      </div>

      <!-- Date Filter Form -->
      <div style="background: var(--white); padding: 2rem; border: 4px solid var(--ink); box-shadow: 10px 10px 0 var(--yellow);">
        <h3 style="font-family: var(--font-h); font-size: 1.2rem; font-weight: 900; margin-bottom: 1.5rem; text-transform: uppercase;">Filter Yield</h3>
        <form action="/host-dashboard" method="GET" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
              <label style="font-size: 0.7rem; font-weight: 900; text-transform: uppercase; display: block; margin-bottom: 0.4rem;">Start</label>
              <input type="date" name="startDate" id="startDate" value="<%= q.startDate || '' %>" style="width: 100%; padding: 0.6rem; border: 2px solid var(--ink); font-family: inherit; font-weight: 700;">
            </div>
            <div>
              <label style="font-size: 0.7rem; font-weight: 900; text-transform: uppercase; display: block; margin-bottom: 0.4rem;">End</label>
              <input type="date" name="endDate" id="endDate" value="<%= q.endDate || '' %>" style="width: 100%; padding: 0.6rem; border: 2px solid var(--ink); font-family: inherit; font-weight: 700;">
            </div>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.5rem;">
            <button type="submit" class="sz-btn sz-btn--action" style="padding: 0.8rem; font-size: 0.8rem;">APPLY FILTER</button>
            <a href="/host-dashboard" class="sz-btn" style="padding: 0.8rem; font-size: 0.8rem; text-align: center; background: var(--lavender); color: var(--white);">RESET</a>
          </div>
        </form>
      </div>

    </div>

    <!-- ANALYTICS DASHBOARD -->

    <div class="sz-analytics-grid">
      
      <!-- Yield Trend Chart -->
      <div class="sz-analytics-card">
        <h3 class="sz-analytics-card__title">
          <i class="fa-solid fa-chart-line"></i> YIELD PROJECTION (6M)
        </h3>
        <div style="height: 300px; position: relative;">
          <canvas id="yieldChart"></canvas>
        </div>
      </div>

      <!-- Occupancy & Performance -->

      <div style="display: flex; flex-direction: column; gap: 2rem;">
        
        <!-- Occupancy Circle -->
        <div class="sz-analytics-card" style="text-align: center; border-color: var(--ink); border-style: double; border-width: 6px;">
          <h3 class="sz-analytics-card__title" style="justify-content: center; font-size: 0.9rem;">DENSITY_LEVEL</h3>
          <div class="sz-occupancy-circle">
            <span class="sz-occupancy-circle__val"><%= occupancyRate %>%</span>
            <span class="sz-occupancy-circle__label">Occupancy</span>
          </div>
          <p style="font-size: 0.65rem; font-weight: 800; color: var(--coral); margin-top: 1rem; text-transform: uppercase;">Current Month Utilization</p>
        </div>

        <!-- Asset Performance Bar -->
        <div class="sz-analytics-card" style="box-shadow: 10px 10px 0 var(--lime);">
          <h3 class="sz-analytics-card__title" style="font-size: 0.9rem;">PERFORMANCE_RANKING</h3>

          <div style="height: 180px; position: relative;">
            <canvas id="assetChart"></canvas>
          </div>
        </div>

      </div>

    </div>

    <!-- UPCOMING RESERVATIONS -->
    <section style="margin-bottom: 5rem;">
      <h2 style="font-family: var(--font-h); font-size: 2rem; font-weight: 900; text-transform: uppercase; border-bottom: 4px solid var(--ink); padding-bottom: 1rem; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between;">
        <span>Upcoming Bookings</span>
        <span style="font-size: 0.9rem; background: var(--ink); color: var(--lime); padding: 4px 12px; letter-spacing: 1px;"><%= upcomingBookings.length %> ACTIVE</span>
      </h2>

      
      <% if(upcomingBookings.length === 0) { %>
        <div class="sz-dashboard__empty" style="background: var(--white); padding: 3rem;">
          <i class="fa-solid fa-calendar-day" style="font-size: 3rem; opacity: 0.2;"></i>
          <h2 style="font-family: var(--font-h); font-size: 1.5rem; margin-top: 1rem;">NO UPCOMING GUESTS</h2>
        </div>
      <% } else { %>
        <div style="border: 4px solid var(--ink); background: var(--white); box-shadow: 12px 12px 0 var(--lavender); overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 800px;">
            <thead>
              <tr style="background: var(--ink); color: var(--cream); font-weight: 900; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px;">
                <th style="padding: 1.2rem; border-right: 2px dashed rgba(245,240,232,0.2);">Listing</th>
                <th style="padding: 1.2rem; border-right: 2px dashed rgba(245,240,232,0.2);">Guest</th>
                <th style="padding: 1.2rem; border-right: 2px dashed rgba(245,240,232,0.2);">Timeline</th>

                <th style="padding: 1.2rem; border-right: 2px dashed rgba(245,240,232,0.2);">Payout</th>
                <th style="padding: 1.2rem; text-align: center;">Status</th>
              </tr>

            </thead>
            <tbody>
              <% upcomingBookings.forEach((booking) => { %>
                <% 
                  let statusBg = 'var(--yellow)';
                  let statusColor = 'var(--ink)';
                  if (booking.status === 'Confirmed') {
                    statusBg = 'var(--lime)';
                    statusColor = 'var(--ink)';
                  } else if (booking.status === 'Declined') {
                    statusBg = 'var(--coral)';
                    statusColor = 'var(--white)';
                  }
                %>
                <tr style="border-bottom: 3px dashed var(--ink);">
                  <td style="padding: 1.2rem; font-weight: 800; border-right: 2px dashed rgba(10,10,10,0.1);">
                    <a href="/listings/<%= booking.listing._id %>" style="color: var(--coral); text-decoration: none;"><%= booking.listing.title %></a>
                  </td>
                  <td style="padding: 1.2rem; border-right: 2px dashed rgba(10,10,10,0.1);">
                    <div style="font-weight: 900; color: var(--ink);"><%= booking.user.username %></div>
                    <div style="font-size: 0.75rem; font-weight: 700; opacity: 0.6;"><%= booking.user.email %></div>
                  </td>
                  <td style="padding: 1.2rem; border-right: 2px dashed rgba(10,10,10,0.1);">
                    <div style="font-weight: 800; font-size: 0.85rem;"><%= booking.checkIn.toLocaleDateString('en-GB') %> → <%= booking.checkOut.toLocaleDateString('en-GB') %></div>
                  </td>
                  <td style="padding: 1.2rem; font-weight: 900; border-right: 2px dashed rgba(10,10,10,0.1);">₹<%= booking.totalPrice.toLocaleString("en-IN") %></td>
                  <td style="padding: 1.2rem; text-align: center;">
                    <span class="sz-status-label sz-status-label--confirmed">
                      CONFIRMED
                    </span>
                  </td>

                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>

    <!-- PAST RESERVATIONS -->
    <section style="margin-bottom: 5rem;">
      <h2 style="font-family: var(--font-h); font-size: 2rem; font-weight: 900; text-transform: uppercase; border-bottom: 4px solid var(--ink); padding-bottom: 1rem; margin-bottom: 2rem;">Past Bookings</h2>

      
      <% if(pastBookings.length === 0) { %>
        <div style="padding: 2rem; border: 4px dashed var(--ink); text-align: center; opacity: 0.5;">
          <p style="font-weight: 800; margin: 0;">NO COMPLETED BOOKINGS</p>

        </div>
      <% } else { %>
        <div style="border: 4px solid var(--ink); background: var(--white); box-shadow: 8px 8px 0 var(--ink); overflow-x: auto; opacity: 0.85;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 800px;">
            <thead>
              <tr style="background: #eee; color: var(--ink); font-weight: 900; text-transform: uppercase; font-size: 0.75rem;">
                <th style="padding: 1rem; border-right: 1px solid #ccc;">Territory</th>
                <th style="padding: 1rem; border-right: 1px solid #ccc;">Guest</th>
                <th style="padding: 1rem; border-right: 1px solid #ccc;">Dates</th>
                <th style="padding: 1rem; text-align: right;">Yield</th>
              </tr>
            </thead>
            <tbody>
              <% pastBookings.forEach((booking) => { %>
                <tr style="border-bottom: 1px solid #eee;">
                  <td style="padding: 1rem; border-right: 1px solid #eee; font-weight: 700;"><%= booking.listing.title %></td>
                  <td style="padding: 1rem; border-right: 1px solid #eee; font-weight: 700;"><%= booking.user.username %></td>
                  <td style="padding: 1rem; border-right: 1px solid #eee; font-size: 0.85rem;"><%= booking.checkIn.toLocaleDateString('en-GB') %> - <%= booking.checkOut.toLocaleDateString('en-GB') %></td>
                  <td style="padding: 1rem; text-align: right; font-weight: 900;">₹<%= booking.totalPrice.toLocaleString("en-IN") %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>

    <!-- OWNED ASSETS -->
    <section>
      <h2 style="font-family: var(--font-h); font-size: 2rem; font-weight: 900; text-transform: uppercase; border-bottom: 4px solid var(--ink); padding-bottom: 1rem; margin-bottom: 2rem;">My Listings</h2>

      
      <% if(listings.length === 0) { %>
        <div class="sz-dashboard__empty" style="background: var(--white);">
          <i class="fa-solid fa-house-flag"></i>
          <h2 style="font-family: var(--font-h); font-size: 2rem;">NO LISTINGS</h2>
          <a href="/listings/new" class="sz-btn sz-btn--action" style="margin-top: 1rem;">LIST NEW PROPERTY</a>

        </div>
      <% } else { %>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
          <% listings.forEach((listing) => { %>
            <div style="background: var(--white); border: 4px solid var(--ink); box-shadow: 8px 8px 0 var(--yellow); display: flex; flex-direction: column;">
              <div style="height: 150px; border-bottom: 3px dashed var(--ink); overflow: hidden;">
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.2);">
              </div>
              <div style="padding: 1.2rem; flex: 1;">
                <h3 style="font-family: var(--font-h); font-size: 1.1rem; font-weight: 900; margin-bottom: 0.4rem; color: var(--ink); text-transform: uppercase;"><%= listing.title %></h3>
                <div style="font-weight: 800; font-size: 0.75rem; color: var(--coral); text-transform: uppercase;">
                  <i class="fa-solid fa-location-dot"></i> <%= listing.location %>
                </div>
              </div>
              <a href="/listings/<%= listing._id %>" style="display: block; padding: 0.8rem; text-align: center; background: var(--ink); color: var(--lime); font-weight: 900; text-transform: uppercase; text-decoration: none; border-top: 4px solid var(--ink); font-size: 0.8rem;">
                VIEW DETAILS
              </a>

            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

  </div>
</main>

<!-- DATA_STORE FOR ANALYTICS (Hidden) -->

<div id="analytics-data" 
     style="display: none;" 
     data-monthly='<%= JSON.stringify(monthlyYield) %>'
     data-performance='<%= JSON.stringify(listingPerformance) %>'>
</div>

<script>
  // --- DATA EXTRACTION ---
  const dataShell = document.getElementById('analytics-data');
  const monthlyYieldData = JSON.parse(dataShell.getAttribute('data-monthly'));
  const performanceDataRaw = JSON.parse(dataShell.getAttribute('data-performance'));

  // --- CHART.JS CONFIGURATION (BRUTALIST STYLE) ---
  const yieldCtx = document.getElementById('yieldChart').getContext('2d');
  const assetCtx = document.getElementById('assetChart').getContext('2d');

  // 1. Yield Trend Chart
  new Chart(yieldCtx, {
    type: 'line',
    data: {
      labels: monthlyYieldData.map(y => y.month),
      datasets: [{
        label: 'YIELD (INR)',
        data: monthlyYieldData.map(y => y.total),
        borderColor: '#0A0A0A',
        backgroundColor: 'rgba(10, 10, 10, 0.05)',
        borderWidth: 4,
        fill: true,
        tension: 0,
        pointBackgroundColor: '#FF4500',
        pointBorderColor: '#0A0A0A',
        pointBorderWidth: 2,
        pointRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(0,0,0,0.1)', borderDash: [5, 5] },
          ticks: { font: { weight: '900', size: 10 } }
        },
        x: {
          grid: { display: false },
          ticks: { font: { weight: '900', size: 10 } }
        }
      },
      plugins: {
        legend: { display: false }
      }
    }
  });

  // 2. Asset Performance Chart
  new Chart(assetCtx, {
    type: 'bar',
    data: {
      labels: performanceDataRaw.map(p => p.title.length > 15 ? p.title.substring(0,12)+'...' : p.title ),
      datasets: [{
        label: 'TOTAL_YIELD',
        data: performanceDataRaw.map(p => p.yield),
        backgroundColor: '#CCFF00',
        borderColor: '#0A0A0A',
        borderWidth: 3
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      indexAxis: 'y',
      scales: {
        y: { 
          grid: { display: false },
          ticks: { font: { weight: '900', size: 9 } }
        },
        x: { 
          display: false 
        }
      },
      plugins: {
        legend: { display: false }
      }
    }
  });
</script>
