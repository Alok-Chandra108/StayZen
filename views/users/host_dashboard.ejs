<%- layout("/layouts/boilerplate") -%>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<main class="sz-dashboard">
  <div class="container">
    
    <header class="sz-dashboard__header">
      <h1 class="sz-dashboard__title" style="flex: 1;">
        <i class="fa-solid fa-chart-pie me-3"></i>Host Dashboard
      </h1>
      <div class="sz-badge sz-badge--action">
        <%= listings.length %> Properties
      </div>
    </header>


    <% 
      // Extract query parameters safely
      const q = locals.searchQuery || {}; 
    %>

    <!-- SUMMARY METRICS & FILTERS -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; align-items: start;">
      
      <!-- Earnings Card -->
      <div style="background: linear-gradient(135deg, var(--navy) 0%, #1a3050 100%); color: var(--white); padding: 2.5rem; border-radius: 20px; position: relative; overflow: hidden; box-shadow: var(--shadow-lg);">
        <div style="font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 0.5rem; color: var(--gold);">Total Revenue</div>
        <div style="font-family: var(--font-h); font-size: 3rem; font-weight: 700; line-height: 1;">₹<%= totalEarnings.toLocaleString("en-IN") %></div>
        <% if(q.startDate || q.endDate) { %>
          <div style="margin-top: 1rem; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; background: rgba(201,169,110,0.2); display: inline-block; padding: 4px 12px; border-radius: 9999px; color: var(--gold);">Filtered Range</div>
        <% } %>
        <i class="fa-solid fa-chart-line" style="position: absolute; bottom: -10px; right: -10px; font-size: 5rem; opacity: 0.06;"></i>
      </div>

      <!-- Date Filter Form -->
      <div style="background: var(--white); padding: 2rem; border: 1px solid var(--border-color); border-radius: 20px; box-shadow: var(--shadow-sm);">
        <h3 style="font-family: var(--font-h); font-size: 1.1rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--navy);">Filter by Date</h3>
        <form action="/host-dashboard" method="GET" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
              <label style="font-size: 0.72rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.4rem; color: var(--text-muted);">Start</label>
              <input type="date" name="startDate" id="startDate" value="<%= q.startDate || '' %>" style="width: 100%; padding: 0.6rem; border: 1px solid var(--border-color); border-radius: 12px; font-family: inherit; font-weight: 500; background: var(--ivory);">
            </div>
            <div>
              <label style="font-size: 0.72rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.4rem; color: var(--text-muted);">End</label>
              <input type="date" name="endDate" id="endDate" value="<%= q.endDate || '' %>" style="width: 100%; padding: 0.6rem; border: 1px solid var(--border-color); border-radius: 12px; font-family: inherit; font-weight: 500; background: var(--ivory);">
            </div>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.5rem;">
            <button type="submit" class="sz-btn sz-btn--action" style="padding: 0.7rem; font-size: 0.82rem; border-radius: 12px;">Apply</button>
            <a href="/host-dashboard" class="sz-btn" style="padding: 0.7rem; font-size: 0.82rem; text-align: center; border-radius: 12px;">Reset</a>
          </div>
        </form>
      </div>

    </div>

    <!-- ANALYTICS DASHBOARD -->

    <div class="sz-analytics-grid">
      
      <!-- Yield Trend Chart -->
      <div class="sz-analytics-card">
        <h3 class="sz-analytics-card__title">
          <i class="fa-solid fa-chart-line"></i> Revenue Trend (6 Months)
        </h3>
        <div style="height: 300px; position: relative;">
          <canvas id="yieldChart"></canvas>
        </div>
      </div>

      <!-- Occupancy & Performance -->

      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- Occupancy Circle -->
        <div class="sz-analytics-card" style="text-align: center;">
          <h3 class="sz-analytics-card__title" style="justify-content: center;">Occupancy Rate</h3>
          <div class="sz-occupancy-circle">
            <span class="sz-occupancy-circle__val"><%= occupancyRate %>%</span>
            <span class="sz-occupancy-circle__label">Occupancy</span>
          </div>
          <p style="font-size: 0.72rem; font-weight: 500; color: var(--text-muted); margin-top: 1rem;">Current Month</p>
        </div>

        <!-- Asset Performance Bar -->
        <div class="sz-analytics-card">
          <h3 class="sz-analytics-card__title">Property Performance</h3>

          <div style="height: 180px; position: relative;">
            <canvas id="assetChart"></canvas>
          </div>
        </div>

      </div>

    </div>

    <!-- UPCOMING RESERVATIONS -->
    <section style="margin-bottom: 4rem;">
      <h2 style="font-family: var(--font-h); font-size: 1.6rem; font-weight: 700; color: var(--navy); border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between;">
        <span>Upcoming Bookings</span>
        <span class="sz-badge sz-badge--action"><%= upcomingBookings.length %> Active</span>
      </h2>

      
      <% if(upcomingBookings.length === 0) { %>
        <div class="sz-dashboard__empty" style="padding: 3rem;">
          <i class="fa-solid fa-calendar-day" style="font-size: 2.5rem;"></i>
          <h2 style="font-family: var(--font-h); font-size: 1.3rem; margin-top: 1rem; color: var(--navy);">No upcoming guests</h2>
        </div>
      <% } else { %>
        <div style="border: 1px solid var(--border-color); background: var(--white); border-radius: 16px; box-shadow: var(--shadow-sm); overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 800px;">
            <thead>
              <tr style="background: var(--navy); color: rgba(255,255,255,0.85); font-weight: 600; font-size: 0.78rem; letter-spacing: 0.5px;">
                <th style="padding: 1rem 1.2rem;">Property</th>
                <th style="padding: 1rem 1.2rem;">Guest</th>
                <th style="padding: 1rem 1.2rem;">Dates</th>

                <th style="padding: 1rem 1.2rem;">Total</th>
                <th style="padding: 1rem 1.2rem; text-align: center;">Status</th>
              </tr>

            </thead>
            <tbody>
              <% upcomingBookings.forEach((booking) => { %>
                <tr style="border-bottom: 1px solid var(--border-color);">
                  <td style="padding: 1rem 1.2rem; font-weight: 600;">
                    <a href="/listings/<%= booking.listing._id %>" style="color: var(--navy); text-decoration: none;"><%= booking.listing.title %></a>
                  </td>
                  <td style="padding: 1rem 1.2rem;">
                    <div style="font-weight: 600; color: var(--navy);"><%= booking.user.username %></div>
                    <div style="font-size: 0.75rem; color: var(--text-muted);"><%= booking.user.email %></div>
                  </td>
                  <td style="padding: 1rem 1.2rem;">
                    <div style="font-weight: 500; font-size: 0.85rem;"><%= booking.checkIn.toLocaleDateString('en-GB') %> → <%= booking.checkOut.toLocaleDateString('en-GB') %></div>
                  </td>
                  <td style="padding: 1rem 1.2rem; font-weight: 700;">₹<%= booking.totalPrice.toLocaleString("en-IN") %></td>
                  <td style="padding: 1rem 1.2rem; text-align: center;">
                    <span class="sz-status-label sz-status-label--confirmed">
                      Confirmed
                    </span>
                  </td>

                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>

    <!-- PAST RESERVATIONS -->
    <section style="margin-bottom: 4rem;">
      <h2 style="font-family: var(--font-h); font-size: 1.6rem; font-weight: 700; color: var(--navy); border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 2rem;">Past Bookings</h2>

      
      <% if(pastBookings.length === 0) { %>
        <div style="padding: 2rem; border: 1px dashed var(--border-color); text-align: center; border-radius: 16px; color: var(--text-muted);">
          <p style="font-weight: 500; margin: 0;">No completed bookings yet</p>

        </div>
      <% } else { %>
        <div style="border: 1px solid var(--border-color); background: var(--white); border-radius: 16px; box-shadow: var(--shadow-xs); overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 800px;">
            <thead>
              <tr style="background: var(--ivory); color: var(--text); font-weight: 600; font-size: 0.75rem; text-transform: uppercase;">
                <th style="padding: 1rem 1.2rem;">Property</th>
                <th style="padding: 1rem 1.2rem;">Guest</th>
                <th style="padding: 1rem 1.2rem;">Dates</th>
                <th style="padding: 1rem 1.2rem; text-align: right;">Amount</th>
              </tr>
            </thead>
            <tbody>
              <% pastBookings.forEach((booking) => { %>
                <tr style="border-bottom: 1px solid var(--border-color);">
                  <td style="padding: 1rem 1.2rem; font-weight: 600;"><%= booking.listing.title %></td>
                  <td style="padding: 1rem 1.2rem; font-weight: 500;"><%= booking.user.username %></td>
                  <td style="padding: 1rem 1.2rem; font-size: 0.85rem;"><%= booking.checkIn.toLocaleDateString('en-GB') %> - <%= booking.checkOut.toLocaleDateString('en-GB') %></td>
                  <td style="padding: 1rem 1.2rem; text-align: right; font-weight: 700;">₹<%= booking.totalPrice.toLocaleString("en-IN") %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>

    <!-- OWNED PROPERTIES -->
    <section>
      <h2 style="font-family: var(--font-h); font-size: 1.6rem; font-weight: 700; color: var(--navy); border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 2rem;">My Properties</h2>

      
      <% if(listings.length === 0) { %>
        <div class="sz-dashboard__empty">
          <i class="fa-solid fa-building"></i>
          <h2 style="font-family: var(--font-h); font-size: 1.5rem; margin-top: 1rem; color: var(--navy);">No Properties Listed</h2>
          <a href="/listings/new" class="sz-btn sz-btn--action" style="margin-top: 1.5rem; border-radius: 9999px;">List Your First Property</a>

        </div>
      <% } else { %>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
          <% listings.forEach((listing) => { %>
            <div style="background: var(--white); border: 1px solid var(--border-color); border-radius: 16px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; overflow: hidden; transition: all 0.3s ease;">
              <div style="height: 160px; overflow: hidden;">
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;">
              </div>
              <div style="padding: 1.2rem; flex: 1;">
                <h3 style="font-family: var(--font-h); font-size: 1rem; font-weight: 700; margin-bottom: 0.3rem; color: var(--navy);"><%= listing.title %></h3>
                <div style="font-weight: 500; font-size: 0.78rem; color: var(--text-light);">
                  <i class="fa-solid fa-location-dot" style="color: var(--gold);"></i> <%= listing.location %>
                </div>
              </div>
              <a href="/listings/<%= listing._id %>" style="display: block; padding: 0.8rem; text-align: center; background: var(--navy); color: var(--gold); font-weight: 600; text-decoration: none; font-size: 0.82rem; transition: background 0.2s;">
                View Details
              </a>

            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

  </div>
</main>

<!-- DATA_STORE FOR ANALYTICS (Hidden) -->

<div id="analytics-data" 
     style="display: none;" 
     data-monthly='<%= JSON.stringify(monthlyYield) %>'
     data-performance='<%= JSON.stringify(listingPerformance) %>'>
</div>

<script>
  // --- DATA EXTRACTION ---
  const dataShell = document.getElementById('analytics-data');
  const monthlyYieldData = JSON.parse(dataShell.getAttribute('data-monthly'));
  const performanceDataRaw = JSON.parse(dataShell.getAttribute('data-performance'));

  // --- CHART.JS CONFIGURATION (Hotel Theme) ---
  const yieldCtx = document.getElementById('yieldChart').getContext('2d');
  const assetCtx = document.getElementById('assetChart').getContext('2d');

  // 1. Revenue Trend Chart
  new Chart(yieldCtx, {
    type: 'line',
    data: {
      labels: monthlyYieldData.map(y => y.month),
      datasets: [{
        label: 'Revenue (INR)',
        data: monthlyYieldData.map(y => y.total),
        borderColor: '#0F1B2D',
        backgroundColor: 'rgba(15, 27, 45, 0.04)',
        borderWidth: 2.5,
        fill: true,
        tension: 0.4,
        pointBackgroundColor: '#C9A96E',
        pointBorderColor: '#0F1B2D',
        pointBorderWidth: 2,
        pointRadius: 5,
        pointHoverRadius: 7
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(0,0,0,0.04)', drawBorder: false },
          ticks: { font: { weight: '500', size: 11, family: 'Inter' } }
        },
        x: {
          grid: { display: false },
          ticks: { font: { weight: '500', size: 11, family: 'Inter' } }
        }
      },
      plugins: {
        legend: { display: false }
      }
    }
  });

  // 2. Property Performance Chart
  new Chart(assetCtx, {
    type: 'bar',
    data: {
      labels: performanceDataRaw.map(p => p.title.length > 15 ? p.title.substring(0,12)+'...' : p.title ),
      datasets: [{
        label: 'Revenue',
        data: performanceDataRaw.map(p => p.yield),
        backgroundColor: '#C9A96E',
        borderColor: '#0F1B2D',
        borderWidth: 1,
        borderRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      indexAxis: 'y',
      scales: {
        y: { 
          grid: { display: false },
          ticks: { font: { weight: '500', size: 10, family: 'Inter' } }
        },
        x: { 
          display: false 
        }
      },
      plugins: {
        legend: { display: false }
      }
    }
  });
</script>
