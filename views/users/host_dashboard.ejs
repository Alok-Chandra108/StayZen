<%- layout("/layouts/boilerplate") -%>

<main class="sz-dashboard">
  <div class="container">
    
    <header class="sz-dashboard__header">
      <h1 class="sz-dashboard__title" style="flex: 1;">
        <i class="fa-solid fa-chess-rook me-3"></i>HOST COMMAND
      </h1>
      <div class="sz-badge sz-badge--action" style="background: var(--lime); color: var(--ink);">
        <%= listings.length %> ASSETS
      </div>
    </header>

    <!-- SUMMARY METRICS -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-bottom: 4rem;">
      <div style="background: var(--coral); color: var(--white); padding: 2rem; border: 4px solid var(--ink); box-shadow: 8px 8px 0 var(--ink); transition: transform 0.2s;">
        <div style="font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 0.5rem; opacity: 0.9;">Total Simulated Yield</div>
        <div style="font-family: var(--font-h); font-size: 3rem; font-weight: 900; line-height: 1;">₹<%= totalEarnings.toLocaleString("en-IN") %></div>
      </div>
      
      <div style="background: var(--lavender); color: var(--white); padding: 2rem; border: 4px solid var(--ink); box-shadow: 8px 8px 0 var(--ink); transition: transform 0.2s;">
        <div style="font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 0.5rem; opacity: 0.9;">Active Bookings</div>
        <div style="font-family: var(--font-h); font-size: 3rem; font-weight: 900; line-height: 1;"><%= bookings.length %></div>
      </div>
    </div>

    <!-- MAIN CONTENT GRID -->
    <div style="display: grid; grid-template-columns: 1fr; gap: 4rem; margin-bottom: 4rem;">
        
      <!-- TARGET ASSETS -->
      <section>
        <h2 style="font-family: var(--font-h); font-size: 2rem; font-weight: 900; text-transform: uppercase; border-bottom: 4px solid var(--ink); padding-bottom: 1rem; margin-bottom: 2rem;">Owned Territories</h2>
        
        <% if(listings.length === 0) { %>
          <div class="sz-dashboard__empty" style="background: var(--white);">
            <i class="fa-solid fa-house-flag"></i>
            <h2 class="sz-dashboard__title" style="font-size: 2rem;">NO TERRITORY</h2>
            <p class="sz-hero__sub" style="margin: 2rem auto; border-left: none; padding: 0;">You haven't listed any properties yet.</p>
            <a href="/listings/new" class="sz-btn sz-btn--action">LIST NEW ASSET</a>
          </div>
        <% } else { %>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
            <% listings.forEach((listing) => { %>
              <div style="background: var(--white); border: 4px solid var(--ink); box-shadow: 8px 8px 0 var(--yellow); position: relative; display: flex; flex-direction: column;">
                <div style="height: 160px; border-bottom: 3px dashed var(--ink); overflow: hidden;">
                  <img src="<%= listing.image.url %>" alt="<%= listing.title %>" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.2) contrast(1.1);">
                </div>
                <div style="padding: 1.5rem; flex: 1;">
                  <h3 style="font-family: var(--font-h); font-size: 1.2rem; font-weight: 900; margin-bottom: 0.5rem; color: var(--ink); text-transform: uppercase;"><%= listing.title %></h3>
                  <div style="font-weight: 800; font-size: 0.8rem; color: var(--coral); text-transform: uppercase; margin-bottom: 1rem;">
                    <i class="fa-solid fa-location-dot"></i> <%= listing.location %>
                  </div>
                  <div style="font-weight: 900; font-size: 1rem; color: var(--ink);">
                    ₹<%= listing.price.toLocaleString("en-IN") %> / night
                  </div>
                </div>
                <a href="/listings/<%= listing._id %>" style="display: block; padding: 1rem; text-align: center; background: var(--ink); color: var(--lime); font-weight: 900; text-transform: uppercase; text-decoration: none; border-top: 4px solid var(--ink);">
                  VIEW INTEL <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>

      <!-- RESERVATIONS -->
      <section>
        <h2 style="font-family: var(--font-h); font-size: 2rem; font-weight: 900; text-transform: uppercase; border-bottom: 4px solid var(--ink); padding-bottom: 1rem; margin-bottom: 2rem;">Incoming Guests</h2>
        
        <% if(bookings.length === 0) { %>
          <div class="sz-dashboard__empty" style="background: var(--white);">
            <i class="fa-solid fa-calendar-xmark"></i>
            <h2 class="sz-dashboard__title" style="font-size: 1.5rem; margin-bottom: 0;">NO INCOMING GUESTS</h2>
          </div>
        <% } else { %>
          <div style="border: 4px solid var(--ink); background: var(--white); box-shadow: 12px 12px 0 var(--coral); overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 600px;">
              <thead>
                <tr style="background: var(--ink); color: var(--cream); font-weight: 900; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px;">
                  <th style="padding: 1.5rem; border-right: 2px dashed rgba(245,240,232,0.2);">Territory</th>
                  <th style="padding: 1.5rem; border-right: 2px dashed rgba(245,240,232,0.2);">Guest</th>
                  <th style="padding: 1.5rem; border-right: 2px dashed rgba(245,240,232,0.2);">Dates</th>
                  <th style="padding: 1.5rem; text-align: right;">Payout</th>
                </tr>
              </thead>
              <tbody>
                <% bookings.forEach((booking) => { %>
                  <tr style="border-bottom: 3px dashed var(--ink);">
                    <td style="padding: 1.5rem; font-weight: 800; border-right: 2px dashed rgba(10,10,10,0.1);"><a href="/listings/<%= booking.listing._id %>" style="color: var(--coral); text-decoration: none;"><%= booking.listing.title %></a></td>
                    <td style="padding: 1.5rem; font-weight: 700; border-right: 2px dashed rgba(10,10,10,0.1);"><%= booking.user.username %></td>
                    <td style="padding: 1.5rem; border-right: 2px dashed rgba(10,10,10,0.1);">
                      <div style="font-weight: 800; font-size: 0.85rem; margin-bottom: 0.25rem;">IN: <%= booking.checkIn.toLocaleDateString('en-GB') %></div>
                      <div style="font-weight: 800; font-size: 0.85rem;">OUT: <%= booking.checkOut.toLocaleDateString('en-GB') %></div>
                    </td>
                    <td style="padding: 1.5rem; text-align: right; font-weight: 900; font-size: 1.2rem;">₹<%= booking.totalPrice.toLocaleString("en-IN") %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>

    </div>
  </div>
</main>
