<% layout("/layouts/boilerplate") %>

<!-- ================================================================
     STAYZEN — LOGIN PAGE / NEU-BRUTALISM × AWWWARDS
     ================================================================ -->
<div class="sz-auth-page">

  <!-- Left Panel — Illustration (hidden on small) -->
  <div class="sz-auth-left" aria-hidden="true">
    <!-- Background SVG pattern -->
    <svg class="sz-auth-bg-svg" viewBox="0 0 400 600" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="auth-dots" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
          <circle cx="12" cy="12" r="2.5" fill="rgba(10,10,10,0.35)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#auth-dots)"/>

      <!-- Decorative shapes -->
      <rect x="40" y="80" width="140" height="140" fill="#C8FF00" stroke="#0A0A0A" stroke-width="5"/>
      <rect x="55" y="95" width="140" height="140" fill="none" stroke="#0A0A0A" stroke-width="2" stroke-dasharray="10 6"/>
      <text x="110" y="168" dominant-baseline="middle" text-anchor="middle" font-family="Space Grotesk" font-weight="900" font-size="52" fill="#0A0A0A">✦</text>

      <circle cx="310" cy="200" r="80" fill="#FF4D2E" stroke="#0A0A0A" stroke-width="5"/>
      <circle cx="310" cy="200" r="55" fill="none" stroke="#0A0A0A" stroke-width="2"/>

      <polygon points="80,340 160,260 240,340" fill="#7C6AF7" stroke="#0A0A0A" stroke-width="5"/>

      <rect x="230" y="380" width="110" height="110" fill="#FFB8C6" stroke="#0A0A0A" stroke-width="5"/>
      <line x1="230" y1="380" x2="340" y2="490" stroke="#0A0A0A" stroke-width="3"/>
      <line x1="340" y1="380" x2="230" y2="490" stroke="#0A0A0A" stroke-width="3"/>

      <text x="200" y="540" text-anchor="middle" font-family="Space Grotesk" font-weight="900" font-size="64" fill="#0A0A0A" opacity="0.06">LOGIN</text>
    </svg>

    <!-- Big text over illustration -->
    <div class="sz-auth-left__text">
      <div class="sz-auth-left__eyebrow">Welcome Back</div>
      <div class="sz-auth-left__big">STAY<br>ZEN</div>
      <div class="sz-auth-left__small">Your next escape awaits.<br>Sign in to continue.</div>
    </div>
  </div>

  <!-- Right Panel — Form -->
  <div class="sz-auth-right">
    <div class="sz-auth-form-card">

      <!-- Form Header -->
      <div class="sz-auth-form-card__header">
        <div class="sz-auth-form-card__eyebrow">Member Login</div>
        <h1 class="sz-auth-form-card__title">Access<br>Account</h1>
      </div>

      <!-- Form Body -->
      <div class="sz-auth-form-card__body">
        <form action="/login" method="post" class="needs-validation" novalidate>

          <div class="sz-auth-field">
            <label for="username" class="sz-auth-label">
              <span class="sz-auth-step">1</span> Username
            </label>
            <input
              name="username"
              id="username"
              type="text"
              class="sz-auth-input"
              placeholder="Enter your username"
              required
              autocomplete="username"
            >
          </div>

          <div class="sz-auth-field">
            <label for="password" class="sz-auth-label">
              <span class="sz-auth-step">2</span> Password
            </label>
            <input
              name="password"
              id="password"
              type="password"
              class="sz-auth-input"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            >
          </div>

          <button class="sz-auth-submit" type="submit">
            <i class="fa-solid fa-right-to-bracket me-2" aria-hidden="true"></i>
            Sign In
          </button>

        </form>

        <div class="sz-auth-switch">
          Don't have an account? <a href="/signup">Sign up for free →</a>
        </div>
      </div>

    </div>
  </div>

</div>

<style>
.sz-auth-page {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
}

/* Left panel */
.sz-auth-left {
  position: relative;
  background: var(--lavender);
  border-right: 4px solid var(--ink);
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  padding: 3rem;
}

.sz-auth-bg-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.sz-auth-left__text {
  position: relative;
  z-index: 2;
}

.sz-auth-left__eyebrow {
  font-size: 0.7rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--lime);
  background: var(--ink);
  padding: 0.35rem 0.8rem;
  display: inline-block;
  margin-bottom: 1rem;
  border: 2px solid var(--lime);
}

.sz-auth-left__big {
  font-size: clamp(4rem, 10vw, 7rem);
  font-weight: 900;
  letter-spacing: -4px;
  line-height: 0.9;
  text-transform: uppercase;
  color: var(--cream);
  text-shadow: 5px 5px 0 var(--ink);
  margin-bottom: 1.5rem;
}

.sz-auth-left__small {
  font-size: 0.9rem;
  font-weight: 500;
  color: rgba(245,240,232,0.8);
  line-height: 1.6;
  border-left: 4px solid var(--lime);
  padding-left: 1rem;
}

/* Right panel */
.sz-auth-right {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3rem 2rem;
  background: var(--cream);
}

.sz-auth-form-card {
  width: 100%;
  max-width: 420px;
  border: 4px solid var(--ink);
  box-shadow: 12px 12px 0 var(--ink);
  background: var(--white);
}

.sz-auth-form-card__header {
  background: var(--ink);
  padding: 2.5rem 2rem 2rem;
}

.sz-auth-form-card__eyebrow {
  font-size: 0.68rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--lime);
  margin-bottom: 0.8rem;
}

.sz-auth-form-card__title {
  font-size: clamp(2.5rem, 6vw, 3.5rem);
  font-weight: 900;
  letter-spacing: -2px;
  line-height: 0.95;
  text-transform: uppercase;
  color: var(--cream);
  margin: 0;
}

.sz-auth-form-card__body { padding: 2rem; }

.sz-auth-field { margin-bottom: 1.5rem; }

.sz-auth-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 0.5rem;
}

.sz-auth-step {
  display: inline-flex;
  width: 22px;
  height: 22px;
  background: var(--coral);
  color: var(--white);
  border: 2px solid var(--ink);
  font-size: 0.75rem;
  font-weight: 900;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sz-auth-input {
  width: 100%;
  border: 3px solid var(--ink) !important;
  border-radius: 0 !important;
  padding: 0.9rem 1rem !important;
  font-size: 0.9rem !important;
  font-family: var(--font-main);
  background: var(--cream) !important;
  color: var(--ink) !important;
  outline: none !important;
  transition: all 0.12s;
  box-shadow: inset 2px 2px 0 rgba(10,10,10,0.06) !important;
}

.sz-auth-input:focus {
  background: var(--white) !important;
  box-shadow: 5px 5px 0 var(--ink) !important;
  transform: translate(-2px, -2px);
}

.sz-auth-submit {
  width: 100%;
  padding: 1rem;
  background: var(--ink);
  color: var(--lime) !important;
  border: 3px solid var(--ink);
  font-family: var(--font-main);
  font-weight: 900;
  font-size: 0.88rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  box-shadow: 6px 6px 0 var(--coral);
  transition: all 0.12s;
  margin-top: 0.5rem;
  cursor: none !important;
}

.sz-auth-submit:hover {
  transform: translate(3px, 3px);
  box-shadow: 3px 3px 0 var(--coral);
}

.sz-auth-switch {
  text-align: center;
  margin-top: 1.5rem;
  font-size: 0.8rem;
  font-weight: 600;
  color: rgba(10,10,10,0.55);
}

.sz-auth-switch a {
  color: var(--lavender);
  font-weight: 800;
  text-decoration: none;
}

.sz-auth-switch a:hover { text-decoration: underline; }

@media (max-width: 768px) {
  .sz-auth-page { grid-template-columns: 1fr; }
  .sz-auth-left { display: none; }
  .sz-auth-right { padding: 2rem 1rem; align-items: flex-start; padding-top: 3rem; }
}
</style>