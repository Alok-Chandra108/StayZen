<% layout("/layouts/boilerplate") %>

<!-- ================================================================
     STAYZEN — LOGIN PAGE
     ================================================================ -->
<div class="sz-auth-page">

  <!-- Left Panel -->
  <div class="sz-auth-left" aria-hidden="true">
    <div class="sz-auth-left__text">
      <div class="sz-auth-left__eyebrow">Welcome Back</div>
      <div class="sz-auth-left__big">Sign<br>In.</div>
      <div class="sz-auth-left__small">Your saved stays are waiting. Sign in with your email to continue your journey.</div>
    </div>
  </div>

  <!-- Right Panel — Form -->
  <div class="sz-auth-right">
    <div class="sz-auth-form-card">

      <div class="sz-auth-form-card__header">
        <div class="sz-auth-form-card__eyebrow">Secure Access</div>
        <h1 class="sz-auth-form-card__title">Welcome<br>Back</h1>
      </div>

      <div class="sz-auth-form-card__body">
        <form action="/login" method="post" class="needs-validation" novalidate>

          <div class="sz-auth-field">
            <label for="email" class="sz-auth-label">
              <span class="sz-auth-step">1</span> Email Address
            </label>
            <input
              name="email"
              id="email"
              type="email"
              class="sz-auth-input"
              placeholder="Enter your email"
              required
              autocomplete="email"
            >
            <div class="invalid-feedback">A registered email is required.</div>
          </div>

          <div class="sz-auth-field">
            <label for="password" class="sz-auth-label">
              <span class="sz-auth-step">2</span> Password
            </label>
            <input
              name="password"
              id="password"
              type="password"
              class="sz-auth-input"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            >
            <div class="invalid-feedback">Password is required.</div>
          </div>

          <button class="sz-auth-submit" type="submit">
            <span class="btn-text">Sign In</span>
            <i class="fa-solid fa-arrow-right ms-2"></i>
          </button>

          <div class="sz-auth-divider">
            <span>OR</span>
          </div>

          <a href="/auth/google" class="sz-auth-google">
            <i class="fa-brands fa-google"></i>
            <span>Continue with Google</span>
          </a>

        </form>

        <div class="sz-auth-switch">
          Don't have an account? <a href="/signup">Create one →</a>
        </div>
      </div>

    </div>
  </div>

</div>