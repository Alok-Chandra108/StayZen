<% layout("/layouts/boilerplate") %>

<!-- ================================================================
     STAYZEN — LOGIN PAGE (REDESIGNED)
     ================================================================ -->
<div class="sz-auth-page">

  <!-- Left Panel — Illustration -->
  <div class="sz-auth-left" aria-hidden="true">
    <svg class="sz-auth-bg-svg" viewBox="0 0 400 600" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="login-pattern" x="0" y="0" width="30" height="30" patternUnits="userSpaceOnUse">
          <circle cx="15" cy="15" r="1.5" fill="rgba(10,10,10,0.2)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#login-pattern)"/>

      <!-- Brutalist geometry -->
      <path d="M 0 400 L 400 600 L 400 300 Z" fill="#C8FF00" stroke="#0A0A0A" stroke-width="4" opacity="0.6"/>
      <rect x="50" y="80" width="120" height="120" fill="#7C6AF7" stroke="#0A0A0A" stroke-width="5"/>
      <rect x="70" y="100" width="120" height="120" fill="none" stroke="#0A0A0A" stroke-width="2"/>
      
      <text x="200" y="320" text-anchor="middle" font-family="Space Grotesk" font-weight="900" font-size="52" fill="#0A0A0A">WELCOME.</text>
    </svg>

    <div class="sz-auth-left__text">
      <div class="sz-auth-left__eyebrow">Returning Guest</div>
      <div class="sz-auth-left__big">STAY<br>ZEN.</div>
      <div class="sz-auth-left__small">Your saved escapes are waiting. Authenticate with your secure email to continue.</div>
    </div>
  </div>

  <!-- Right Panel — Form -->
  <div class="sz-auth-right">
    <div class="sz-auth-form-card">

      <div class="sz-auth-form-card__header" style="background: var(--yellow);">
        <div class="sz-auth-form-card__eyebrow" style="color: var(--ink);">Secure Access</div>
        <h1 class="sz-auth-form-card__title">Sign In<br>Portal</h1>
      </div>

      <div class="sz-auth-form-card__body">
        <form action="/login" method="post" class="needs-validation" novalidate>

          <div class="sz-auth-field">
            <label for="email" class="sz-auth-label">
              <span class="sz-auth-step">1</span> Registered Email
            </label>
            <input
              name="email"
              id="email"
              type="email"
              class="sz-auth-input"
              placeholder="Enter your email"
              required
              autocomplete="email"
            >
            <div class="invalid-feedback">A registered email is required.</div>
          </div>

          <div class="sz-auth-field">
            <label for="password" class="sz-auth-label">
              <span class="sz-auth-step">2</span> Security Key
            </label>
            <input
              name="password"
              id="password"
              type="password"
              class="sz-auth-input"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            >
            <div class="invalid-feedback">Password is required.</div>
          </div>

          <button class="sz-auth-submit" type="submit">
            <span class="btn-text">Authenticate Access</span>
            <i class="fa-solid fa-unlock-keyhole ms-2"></i>
          </button>

        </form>

        <div class="sz-auth-switch">
          Not a member yet? <a href="/signup">Join Securely →</a>
        </div>
      </div>

    </div>
  </div>

</div>