<% layout("/layouts/boilerplate") %>

<div class="sz-verify-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                
                <div class="sz-verify-card <%= status === 'Verified' ? 'sz-verify-card--success' : 'sz-verify-card--danger' %>">
                    
                    <!-- Header -->
                    <div class="sz-verify-header">
                        <div class="sz-verify-eyebrow">Booking Verification</div>
                        <h1 class="sz-verify-title">Booking Confirmed</h1>

                        <div class="sz-verify-status-badge">
                            VERIFIED
                        </div>
                    </div>

                    <!-- Body -->
                    <div class="sz-verify-body">
                        <% if (booking) { %>
                            
                            <div class="sz-verify-intel">

                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <div class="sz-intel-item">
                                            <label>Property</label>
                                            <div class="value"><%= booking.listing.title %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="sz-intel-item">
                                            <label>Guest</label>
                                            <div class="value"><%= booking.user.username %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="sz-intel-item">
                                            <label>Check-In</label>
                                            <div class="value"><%= booking.checkIn.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="sz-intel-item">
                                            <label>Check-Out</label>
                                            <div class="value"><%= booking.checkOut.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="sz-intel-secondary mt-4">
                                    <div class="sz-intel-sub">Listing ID: <%= booking.listing._id %></div>
                                    <div class="sz-intel-sub">Booking ID: <%= booking._id %></div>
                                </div>
                            </div>

                            <div class="sz-verify-footer mt-5">
                                <div class="sz-access-alert">
                                    <i class="fa-solid fa-circle-check me-2"></i>
                                    Booking Verified Successfully
                                </div>
                            </div>


                        <% } else { %>
                            
                            <div class="sz-verify-error text-center py-5">
                                <div class="sz-error-icon mb-4">
                                    <i class="fa-solid fa-triangle-exclamation"></i>
                                </div>
                                <h3>Verification Failed</h3>
                                <p>The scanned pass is either invalid, expired, or has not been confirmed by the host.</p>
                                
                                <% if (booking && booking.status !== 'Confirmed') { %>
                                    <div class="sz-status-note mt-3">
                                        Current Status: <strong><%= booking.status.toUpperCase() %></strong>
                                    </div>
                                <% } %>

                                <div class="mt-5">
                                    <a href="/" class="sz-btn sz-btn--action" style="border-radius: 12px;">Return Home</a>
                                </div>
                            </div>

                        <% } %>
                    </div>

                    <!-- Bottom decoration bar -->
                    <div class="sz-verify-decoration">
                        <div class="sz-verify-tape">BOOKING CONFIRMED ✦ STAYZEN ✦ VERIFIED ✦ BOOKING CONFIRMED ✦ STAYZEN ✦ VERIFIED ✦</div>
                    </div>


                </div>

            </div>
        </div>
    </div>
</div>

<style>
.sz-verify-page {
    background-color: var(--ivory);
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 2rem 0;
}

.sz-verify-card {
    background: var(--white);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    position: relative;
    overflow: hidden;
}

.sz-verify-card--success { }
.sz-verify-card--danger { border-color: #FECACA; }

.sz-verify-header {
    background: var(--navy);
    color: var(--white);
    padding: 3rem 2.5rem;
    position: relative;
}

.sz-verify-card--danger .sz-verify-header { background: var(--danger); }

.sz-verify-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gold);
    margin-bottom: 0.5rem;
}

.sz-verify-title {
    font-family: var(--font-h);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.5px;
    margin: 0;
    text-transform: none;
}

.sz-verify-status-badge {
    position: absolute;
    top: 50%;
    right: 2.5rem;
    transform: translateY(-50%);
    padding: 0.6rem 1.2rem;
    background: #ECFDF5;
    color: #047857;
    border: 1px solid #A7F3D0;
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: var(--radius-full);
    letter-spacing: 0.5px;
}

.sz-verify-card--danger .sz-verify-status-badge {
    background: #FEF2F2;
    color: #991B1B;
    border-color: #FECACA;
}

.sz-verify-body {
    padding: 3rem 2.5rem;
}

.sz-intel-item label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
}

.sz-intel-item .value {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.3;
}

.sz-intel-secondary {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
}

.sz-intel-sub {
    font-size: 0.72rem;
    font-family: monospace;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
}

.sz-access-alert {
    background: #ECFDF5;
    color: #047857;
    padding: 1rem 1.5rem;
    font-weight: 600;
    text-align: center;
    border: 1px solid #A7F3D0;
    border-radius: var(--radius-md);
    letter-spacing: 0.3px;
}

.sz-verify-error h3 {
    font-family: var(--font-h);
    font-weight: 700;
    font-size: 2rem;
    letter-spacing: -0.5px;
    color: var(--danger);
}

.sz-error-icon {
    font-size: 4rem;
    color: var(--danger);
}

.sz-verify-decoration {
    position: relative;
    height: 36px;
    background: var(--navy);
    overflow: hidden;
}

.sz-verify-tape {
    color: var(--gold);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
    padding-top: 10px;
    letter-spacing: 3px;
    animation: tapeScroll 20s linear infinite;
}

@keyframes tapeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
}

.sz-verify-barcode { display: none; }
</style>
